// ══════════════════════════════════════════
// INVENTORY
// ══════════════════════════════════════════
function renderInventoryTable(){
  document.getElementById('inventoryBody').innerHTML=PRODUCTS.map(p=>{
    const reserved=Math.min(Math.floor(p.stock*0.2),3);
    const avail=Math.max(p.stock-reserved,0);
    const statusClass=p.stock===0?'out-of-stock':p.stock<=3?'processing':'in-stock';
    const statusLabel=p.stock===0?'Out of Stock':p.stock<=3?'Low Stock':'In Stock';
    return `<tr>
      <td style="font-weight:600;color:var(--coffee);">${p.name}</td>
      <td>${collNames[p.collection]}</td>
      <td>${p.stock}</td>
      <td>${reserved}</td>
      <td style="font-weight:600;">${avail}</td>
      <td><span class="badge badge-${statusClass}">${statusLabel}</span></td>
      <td><button class="act-btn" onclick="restockProduct(${p.id})" title="Restock">📦</button></td>
    </tr>`;
  }).join('');
}
function restockProduct(id){
  const p=PRODUCTS.find(x=>x.id===id);
  if(!p) return;
  const qty=prompt(`Restock "${p.name}"\nCurrent stock: ${p.stock}\nEnter units to add:`);
  if(qty&&!isNaN(qty)){
    p.stock+=parseInt(qty);
    renderInventoryTable();
    applyProductFilters();
    showToast(`${p.name} restocked by ${qty} units ✓`);
  }
}

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}
