function renderOrdersTable(data){
  document.getElementById('ordersBody').innerHTML=data.map(o=>`
    <tr>
      <td style="font-weight:600;color:var(--coffee);font-size:0.65rem;">${o.id}</td>
      <td>${o.date}</td>
      <td>${o.customer}</td>
      <td>${o.items}</td>
      <td style="font-weight:600;">₦${o.total.toLocaleString()}</td>
      <td>${o.delivery}</td>
      <td>
        <select style="border:1px solid rgba(59,31,14,0.15);background:var(--ivory);font-family:'Montserrat',sans-serif;font-size:0.58rem;padding:0.3rem 0.5rem;cursor:pointer;outline:none;" onchange="updateOrderStatus('${o.id}',this.value)">
          ${['Pending','Processing','Shipped','Delivered','Cancelled'].map(s=>`<option ${s===o.status?'selected':''}>${s}</option>`).join('')}
        </select>
      </td>
      <td>
        <button class="act-btn" onclick="viewOrder('${o.id}')" title="View">👁</button>
        <button class="act-btn del" onclick="showToast('Order ${o.id} archived')" title="Archive">🗄</button>
      </td>
    </tr>`).join('');
}
function filterOrders(q){
  ordersFilter=q.toLowerCase();
  applyOrderFilters();
}
function filterOrdersByStatus(s){
  ordersStatusFilter=s;
  applyOrderFilters();
}
function applyOrderFilters(){
  let data=ORDERS.filter(o=>{
    const q=ordersFilter;
    const matchQ=!q||o.id.toLowerCase().includes(q)||o.customer.toLowerCase().includes(q);
    const matchS=!ordersStatusFilter||o.status===ordersStatusFilter;
    return matchQ&&matchS;
  });
  renderOrdersTable(data);
}
function updateOrderStatus(id,status){
  const o=ORDERS.find(x=>x.id===id);
  if(o){o.status=status;showToast(`Order ${id} → ${status}`);}
  renderRecentOrders();
}
function viewOrder(id){
  const o=ORDERS.find(x=>x.id===id);
  if(!o) return;
  document.getElementById('orderModalTitle').textContent=`Order ${o.id}`;
  document.getElementById('orderModalBody').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
      <div><div class="form-label">Customer</div><strong style="font-size:0.8rem;color:var(--coffee);">${o.customer}</strong></div>
      <div><div class="form-label">Date</div><span style="font-size:0.75rem;">${o.date}</span></div>
      <div><div class="form-label">Email</div><span style="font-size:0.72rem;">${o.email}</span></div>
      <div><div class="form-label">Phone</div><span style="font-size:0.72rem;">${o.phone}</span></div>
    </div>
    <div style="background:var(--ivory);padding:1rem;margin-bottom:1rem;">
      <div class="form-label" style="margin-bottom:0.5rem;">Items Ordered</div>
      <div style="font-size:0.75rem;color:var(--text-dark);">${o.items}</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
      <div><div class="form-label">Total</div><strong style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--coffee);">₦${o.total.toLocaleString()}</strong></div>
      <div><div class="form-label">Delivery</div><span style="font-size:0.75rem;">${o.delivery}</span></div>
      <div><div class="form-label">Status</div><span class="badge badge-${o.status.toLowerCase()}">${o.status}</span></div>
    </div>
    <div style="margin-top:1.5rem;">
      <label class="form-label">Update Status</label>
      <select class="form-input">
        ${['Pending','Processing','Shipped','Delivered','Cancelled'].map(s=>`<option ${s===o.status?'selected':''}>${s}</option>`).join('')}
      </select>
    </div>`;
  document.getElementById('orderModal').classList.add('open');
}
function closeOrderModal(){ document.getElementById('orderModal').classList.remove('open'); }
function exportOrders(){
  const rows=[['Order ID','Date','Customer','Items','Total','Delivery','Status'],...ORDERS.map(o=>[o.id,o.date,o.customer,o.items,o.total,o.delivery,o.status])];
  const csv=rows.map(r=>r.join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='presh-orders.csv';a.click();
  showToast('Orders exported as CSV ✓');
}

