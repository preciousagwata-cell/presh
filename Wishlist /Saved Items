<script>
// ══════════════════════════════════════════
// PRODUCT DATA
// ══════════════════════════════════════════
const ALL_PRODUCTS = [
  {id:1,collection:'professional',name:'Executive Sleek Bob',sub:'9 to 5 Professional',price:85000,oldPrice:110000,badge:'Bestseller',rating:5,reviews:42,desc:'A power wig designed for the boardroom. Silky straight, lace front, pre-plucked hairline with baby hairs.',tags:['Lace Front','Silky Straight','Pre-Plucked'],img:'https://picsum.photos/seed/pw1/480/640'},
