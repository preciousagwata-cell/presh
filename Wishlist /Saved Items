  {id:3,collection:'professional',name:'Boardroom Silk Press',sub:'9 to 5 Professional',price:95000,oldPrice:null,badge:null,rating:4,reviews:26,desc:'Mimics a perfect silk press. Heat-resistant fibres that hold styling beautifully.',tags:['Silk Press','Heat-Resistant','Adjustable Cap'],img:'https://picsum.photos/seed/pw3/480/640'},
  {id:4,collection:'professional',name:'Corporate Closure Queen',sub:'9 to 5 Professional',price:78000,oldPrice:95000,badge:'Sale',rating:5,reviews:31,desc:'A sleek 4x4 closure wig with a clean centre part.',tags:['Closure','Centre Part','Shine'],img:'https://picsum.photos/seed/pw4/480/640'},
  {id:5,collection:'professional',name:'Velvet Straight 180%',sub:'9 to 5 Professional',price:140000,oldPrice:null,badge:'Premium',rating:5,reviews:57,desc:'Ultra-dense 180% density lace front with a velvet-like feel.',tags:['180% Density','Velvet Texture','Statement'],img:'https://picsum.photos/seed/pw5/480/640'},
  {id:6,collection:'professional',name:'Midnight Bob Lace',sub:'9 to 5 Professional',price:92000,oldPrice:null,badge:null,rating:4,reviews:14,desc:'A chic blunt bob that grazes the shoulders. Jet black with a subtle gloss finish.',tags:['Bob','Blunt Cut','Jet Black'],img:'https://picsum.photos/seed/pw6/480/640'},
  {id:7,collection:'student',name:'Campus Chic Curls',sub:'Students Collection',price:45000,oldPrice:null,badge:'Popular',rating:5,reviews:63,desc:'Bouncy natural curls that go from lecture hall to late-night hangout.',tags:['Curly','Lightweight','Natural Look'],img:'https://picsum.photos/seed/sw1/480/640'},
  {id:8,collection:'student',name:'Study Hall Glam',sub:'Students Collection',price:55000,oldPrice:65000,badge:'Sale',rating:4,reviews:29,desc:'Sleek, straight, and budget-friendly luxury.',tags:['Straight','Budget Luxury','Deep Wave'],img:'https://picsum.photos/seed/sw2/480/640'},
  {id:9,collection:'student',name:'Effortless Wave Unit',sub:'Students Collection',price:38000,oldPrice:null,badge:null,rating:3,reviews:8,desc:'Beachy loose waves that require zero styling effort.',tags:['Loose Wave','No Styling','Easy Wear'],img:'https://picsum.photos/seed/sw3/480/640'},
  {id:10,collection:'student',name:'Weekend Kinks',sub:'Students Collection',price:32000,oldPrice:null,badge:'New',rating:5,reviews:11,desc:'Natural kinky coils that celebrate your roots.',tags:['Kinky','Natural','Protective'],img:'https://picsum.photos/seed/sw4/480/640'},
  {id:11,collection:'errand',name:'On-The-Go Ponytail',sub:'Errand & Gym',price:28000,oldPrice:null,badge:null,rating:4,reviews:22,desc:'High ponytail unit that stays put through runs and errands.',tags:['Ponytail','Secure Grip','Sporty'],img:'https://picsum.photos/seed/ew1/480/640'},
  {id:12,collection:'errand',name:'Sweat-Proof Braid Unit',sub:'Errand & Gym',price:32000,oldPrice:null,badge:'New',rating:5,reviews:34,desc:'Box braid wig unit engineered for active women.',tags:['Braids','Moisture-Wick','Active'],img:'https://picsum.photos/seed/ew2/480/640'},
  {id:13,collection:'errand',name:'Active Kinks & Coils',sub:'Errand & Gym',price:22000,oldPrice:null,badge:null,rating:4,reviews:17,desc:'Afro kinks unit perfect for high-intensity workouts.',tags:['Afro','Breathable','Gym'],img:'https://picsum.photos/seed/ew3/480/640'},
  {id:14,collection:'errand',name:'Quick-Fix Twist Out',sub:'Errand & Gym',price:25000,oldPrice:30000,badge:'Sale',rating:4,reviews:9,desc:'A twist-out style wig for when you need to dash out.',tags:['Twist Out','Quick Wear','Effortless'],img:'https://picsum.photos/seed/ew4/480/640'},
  {id:15,collection:'raw',name:'Vietnamese Raw Bundle',sub:'Raw Hairs',price:150000,oldPrice:null,badge:'Premium',rating:5,reviews:48,desc:'Single-donor Vietnamese raw hair — silky, strong, and gloriously thick.',tags:['Single Donor','Dyeable','Bleachable'],img:'https://picsum.photos/seed/rw1/480/640'},
  {id:16,collection:'raw',name:'Cambodian Wavy Raw',sub:'Raw Hairs',price:175000,oldPrice:null,badge:'Premium',rating:5,reviews:39,desc:'Authentic Cambodian wavy texture that tightens beautifully in water.',tags:['Cambodian','Wavy','Water-Friendly'],img:'https://picsum.photos/seed/rw2/480/640'},
  {id:17,collection:'raw',name:'Burmese Straight Raw',sub:'Raw Hairs',price:160000,oldPrice:195000,badge:'Sale',rating:4,reviews:21,desc:'Luxurious Burmese straight raw hair with natural shine.',tags:['Burmese','Straight','Dense'],img:'https://picsum.photos/seed/rw3/480/640'},
  {id:18,collection:'raw',name:'Indian Loose Deep',sub:'Raw Hairs',price:145000,oldPrice:null,badge:'New',rating:5,reviews:15,desc:'Natural Indian loose deep wave raw bundles.',tags:['Indian','Loose Deep','Minimal Shed'],img:'https://picsum.photos/seed/rw4/480/640'},
  {id:19,collection:'perfume',name:'Presh Noir Absolue',sub:'Perfumes',price:65000,oldPrice:null,badge:'Bestseller',rating:5,reviews:71,desc:'Top: Black Pepper, Bergamot. Heart: Oud, Dark Rose. Base: Musk, Amber, Sandalwood.',tags:['Oud','Dark Floral','Sensual'],img:'https://picsum.photos/seed/perf1/480/640'},
  {id:20,collection:'perfume',name:'Velvet Dusk',sub:'Perfumes',price:48000,oldPrice:null,badge:null,rating:4,reviews:33,desc:'A warm, enveloping fragrance of vanilla, iris, and cashmere.',tags:['Vanilla','Iris','Cashmere'],img:'https://picsum.photos/seed/perf2/480/640'},
  {id:21,collection:'perfume',name:'Golden Hour',sub:'Perfumes',price:52000,oldPrice:null,badge:'New',rating:5,reviews:22,desc:'A luminous floral of jasmine, tuberose, and tonka.',tags:['Jasmine','Tuberose','Tonka'],img:'https://picsum.photos/seed/perf3/480/640'},
];

const COLLECTION_LABELS = {professional:'9 to 5 Professional',student:'Students Collection',errand:'Errand & Gym',raw:'Raw Hairs',perfume:'Perfumes'};

// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
// Default wishlist — includes products with price drops for demo
let wishlistIds = JSON.parse(localStorage.getItem('preshWishlistIds') || '[1,3,5,7,15,19,8,17]');
let wishlistDates = JSON.parse(localStorage.getItem('preshWishlistDates') || '{}');
let cart = JSON.parse(localStorage.getItem('preshCart') || '[]');
let selected = new Set();
let selectMode = false;
let currentSort = 'date-desc';
let currentCollFilter = '';
let currentView = 'grid';
let toastTimer;

// Ensure dates exist for all items
wishlistIds.forEach(id => { if(!wishlistDates[id]) wishlistDates[id] = new Date(Date.now() - Math.random()*30*24*60*60*1000).toISOString(); });
saveWishlistDates();

// PRICE DROP DATA (items that have dropped since saved)
const PRICE_DROPS = [
  {id:1, oldSavedPrice:110000, currentPrice:85000},
  {id:17, oldSavedPrice:195000, currentPrice:160000},
];

function saveWishlist(){ localStorage.setItem('preshWishlistIds', JSON.stringify(wishlistIds)); }
function saveWishlistDates(){ localStorage.setItem('preshWishlistDates', JSON.stringify(wishlistDates)); }
function saveCart(){ localStorage.setItem('preshCart', JSON.stringify(cart)); }

// ══════════════════════════════════════════
// COMPUTED
// ══════════════════════════════════════════
function getWishlistProducts(){
  return wishlistIds.map(id => ALL_PRODUCTS.find(p => p.id === id)).filter(Boolean);
}
function getFilteredProducts(){
  let items = getWishlistProducts();
  if(currentCollFilter) items = items.filter(p => p.collection === currentCollFilter);
  if(currentSort === 'date-desc') items.sort((a,b) => new Date(wishlistDates[b.id]) - new Date(wishlistDates[a.id]));
  else if(currentSort === 'date-asc') items.sort((a,b) => new Date(wishlistDates[a.id]) - new Date(wishlistDates[b.id]));
  else if(currentSort === 'price-asc') items.sort((a,b) => a.price - b.price);
  else if(currentSort === 'price-desc') items.sort((a,b) => b.price - a.price);
  else if(currentSort === 'name-asc') items.sort((a,b) => a.name.localeCompare(b.name));
  return items;
}
function totalValue(){ return getWishlistProducts().reduce((s,p) => s+p.price, 0); }

// ══════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════
function renderAll(){
  updateHeroStats();
  renderGrid();
  renderCollectionsPanel();
  renderPriceDropsPanel();
  renderRecommended();
  updateCartBadge();
  document.getElementById('tc-all').textContent = wishlistIds.length;
}

function updateHeroStats(){
  document.getElementById('heroItemCount').textContent = wishlistIds.length;
  document.getElementById('heroTotalValue').textContent = '₦'+(totalValue()/1000).toFixed(0)+'k';
  document.getElementById('heroPriceDrops').textContent = PRICE_DROPS.filter(d => wishlistIds.includes(d.id)).length;
}

function renderGrid(){
  const grid = document.getElementById('wishlistGrid');
  const items = getFilteredProducts();
  if(!items.length){
    grid.innerHTML = `<div style="grid-column:1/-1;"><div class="empty-wishlist">
      <div class="empty-heart">♡</div>
      <h2>${currentCollFilter ? 'No items in this collection' : 'Your wishlist is empty'}</h2>
      <p>${currentCollFilter ? 'You haven\'t saved any items from this collection yet.' : 'Start exploring and save your favourite pieces — they\'ll live here waiting for you.'}</p>
      <div class="empty-btns">
        <a class="empty-btn primary" href="collection.html">Browse Collections</a>
        <a class="empty-btn secondary" href="search.html">Search Products</a>
      </div>
    </div></div>`;
    document.getElementById('recommendedSection').style.display = 'block';
    return;
  }
  document.getElementById('recommendedSection').style.display = 'block';
  const savedDate = id => { const d = new Date(wishlistDates[id]); return d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}); };
  const priceDrop = id => PRICE_DROPS.find(d => d.id === id);

  grid.innerHTML = items.map((p,i) => {
    const drop = priceDrop(p.id);
    const isSelected = selected.has(p.id);
    const saveAmt = p.oldPrice ? Math.round((1-p.price/p.oldPrice)*100) : null;
    return `<div class="wish-card ${isSelected?'selected':''}" style="animation-delay:${Math.min(i,8)*0.05}s;" id="wc-${p.id}">
      <div class="wish-image" onclick="${selectMode?`toggleSelect(${p.id})`:`goToProduct(${p.id})`}">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        ${p.badge?`<span class="wish-badge ${p.badge.toLowerCase()}">${p.badge}</span>`:''}
        ${drop?`<span class="wish-badge sale" style="top:auto;bottom:0.7rem;left:0.7rem;background:rgba(26,122,26,0.9);">↓ Price Drop</span>`:''}
        <div class="wish-select-check" onclick="event.stopPropagation();toggleSelect(${p.id})">✓</div>
        <div class="wish-actions-hover">
          <button class="wish-action-btn cart" onclick="event.stopPropagation();addToCart(${p.id})">Add to Cart</button>
          <button class="wish-action-btn view" onclick="event.stopPropagation();goToProduct(${p.id})">View</button>
        </div>
      </div>
      <div class="wish-body">
        <div class="wish-collection">${p.sub}</div>
        <div class="wish-name" onclick="goToProduct(${p.id})">${p.name}</div>
        <div class="wish-rating">
          <span class="wish-stars">${'★'.repeat(p.rating)}${'☆'.repeat(5-p.rating)}</span>
          <span class="wish-review-ct">(${p.reviews})</span>
        </div>
        <div class="list-desc">${p.desc}</div>
        <div class="list-tags">${p.tags.map(t=>`<span class="list-tag">${t}</span>`).join('')}</div>
        <div class="wish-price-row">
          ${drop
            ? `<span class="wish-price" style="color:var(--green);">₦${p.price.toLocaleString()}</span><span class="wish-old-price">₦${drop.oldSavedPrice.toLocaleString()}</span><span class="wish-save-label">You save ₦${(drop.oldSavedPrice-p.price).toLocaleString()}</span>`
            : `<span class="wish-price">₦${p.price.toLocaleString()}</span>${p.oldPrice?`<span class="wish-old-price">₦${p.oldPrice.toLocaleString()}</span><span class="wish-save-label">Save ${saveAmt}%</span>`:''}`
          }
        </div>
        <div class="list-btn-row">
          <button class="list-btn primary" onclick="addToCart(${p.id})">Add to Cart</button>
          <button class="list-btn secondary" onclick="goToProduct(${p.id})">View Details</button>
          <button class="list-btn remove" onclick="removeItem(${p.id})">Remove</button>
        </div>
        <div class="wish-footer">
          <span class="wish-date">Saved ${savedDate(p.id)}</span>
          <button class="wish-remove-btn" onclick="removeItem(${p.id})">Remove ✕</button>
        </div>
      </div>
      <div class="wish-notify" id="wn-${p.id}">✓ Added to Cart</div>
    </div>`;
  }).join('');
}

function renderCollectionsPanel(){
  const panel = document.getElementById('collectionsPanel');
  const collections = [...new Set(getWishlistProducts().map(p=>p.collection))];
  if(!collections.length){ panel.innerHTML=`<div class="empty-wishlist"><div class="empty-heart">♡</div><h2>Nothing saved yet</h2><p>Save products to see them organised by collection.</p><div class="empty-btns"><a class="empty-btn primary" href="collection.html">Browse Collections</a></div></div>`; return; }
  panel.innerHTML = collections.map(c => {
    const items = getWishlistProducts().filter(p=>p.collection===c);
    return `<div class="collection-group">
      <div class="cg-header">
        <span class="cg-title">${COLLECTION_LABELS[c]}</span>
        <span class="cg-count">${items.length} item${items.length!==1?'s':''}</span>
      </div>
      <div class="cg-body">${items.map(p=>`
        <div class="cg-item" onclick="goToProduct(${p.id})">
          <img class="cg-img" src="${p.img}" alt="${p.name}" loading="lazy"/>
          <div><div class="cg-item-name">${p.name}</div><div class="cg-item-price">₦${p.price.toLocaleString()}</div></div>
        </div>`).join('')}
      </div>
    </div>`;
  }).join('');
}

function renderPriceDropsPanel(){
  const panel = document.getElementById('priceDropsPanel');
  const drops = PRICE_DROPS.filter(d => wishlistIds.includes(d.id)).map(d => ({...ALL_PRODUCTS.find(p=>p.id===d.id), savedAt:d.oldSavedPrice, drop:d}));
  if(!drops.length){ panel.innerHTML=`<div class="empty-wishlist"><div class="empty-heart">📉</div><h2>No price drops right now</h2><p>We'll alert you here when prices drop on your saved items.</p></div>`; return; }
  document.getElementById('tc-drops').textContent = drops.length;
  panel.innerHTML = drops.map(p => {
    const saved = Math.round((1-p.price/p.savedAt)*100);
    return `<div class="price-drop-card">
      <img class="pd-img" src="${p.img}" alt="${p.name}" loading="lazy"/>
      <div>
        <div class="pd-sub">${p.sub}</div>
        <div class="pd-name">${p.name}</div>
        <div class="pd-price-row">
          <span class="pd-new-price">₦${p.price.toLocaleString()}</span>
          <span class="pd-old-price">₦${p.savedAt.toLocaleString()}</span>
        </div>
        <span class="pd-save">You save ₦${(p.savedAt-p.price).toLocaleString()} (${saved}% off)</span>
      </div>
      <div class="pd-actions">
        <button class="pd-btn gold" onclick="addToCart(${p.id})">Add to Cart</button>
        <button class="pd-btn outline" onclick="goToProduct(${p.id})">View Details</button>
        <button class="pd-btn outline" onclick="removeItem(${p.id})" style="border-color:rgba(192,57,43,0.2);color:var(--red);">Remove</button>
      </div>
    </div>`;
  }).join('');
}

function renderRecommended(){
  const inWish = new Set(wishlistIds);
  const recs = ALL_PRODUCTS.filter(p=>!inWish.has(p.id)).sort(()=>Math.random()-0.5).slice(0,5);
  document.getElementById('recGrid').innerHTML = recs.map(p=>`
    <a class="rec-card" href="product.html?id=${p.id}">
      <div class="rec-img">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        <button class="rec-wish-btn" onclick="event.preventDefault();event.stopPropagation();quickSave(${p.id},this)" title="Save to wishlist">♡</button>
      </div>
      <div class="rec-name">${p.name}</div>
      <div class="rec-price">₦${p.price.toLocaleString()}</div>
    </a>`).join('');
}

function updateCartBadge(){
  const total = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('navCartCount').textContent = total;
}

// ══════════════════════════════════════════
// ACTIONS
// ══════════════════════════════════════════
function addToCart(id){
  const p = ALL_PRODUCTS.find(x=>x.id===id);
  if(!p) return;
  cart = JSON.parse(localStorage.getItem('preshCart')||'[]');
  const ex = cart.find(i=>i.id===id);
  if(ex) ex.qty++;
  else cart.push({id:p.id,name:p.name,sub:p.sub,price:p.price,img:p.img,length:'14"',color:'Jet Black',qty:1});
  saveCart();
  updateCartBadge();
  const n = document.getElementById('wn-'+id);
  if(n){ n.classList.add('show'); setTimeout(()=>n.classList.remove('show'), 2200); }
  showToast(`${p.name} added to cart`, 'success');
}

function removeItem(id){
  wishlistIds = wishlistIds.filter(i=>i!==id);
  delete wishlistDates[id];
  selected.delete(id);
  saveWishlist(); saveWishlistDates();
  renderAll();
  showToast('Removed from wishlist');
  updateBulkBar();
}

function goToProduct(id){ window.location.href = `product.html?id=${id}`; }

function addAllToCart(){
  const items = getFilteredProducts();
  if(!items.length){ showToast('No items to add','error'); return; }
  cart = JSON.parse(localStorage.getItem('preshCart')||'[]');
  items.forEach(p=>{
    const ex = cart.find(i=>i.id===p.id);
    if(ex) ex.qty++;
    else cart.push({id:p.id,name:p.name,sub:p.sub,price:p.price,img:p.img,length:'14"',color:'Jet Black',qty:1});
  });
  saveCart(); updateCartBadge();
  showToast(`${items.length} items added to cart 🛍`, 'success');
}

function clearWishlist(){
  if(!wishlistIds.length){ showToast('Wishlist is already empty'); return; }
  if(!confirm(`Remove all ${wishlistIds.length} items from your wishlist?`)) return;
  wishlistIds=[]; wishlistDates={}; selected.clear();
  saveWishlist(); saveWishlistDates();
  renderAll();
  showToast('Wishlist cleared');
  updateBulkBar();
}

function quickSave(id, btn){
  if(wishlistIds.includes(id)){ showToast('Already in wishlist'); return; }
  wishlistIds.push(id);
  wishlistDates[id] = new Date().toISOString();
  saveWishlist(); saveWishlistDates();
  btn.textContent='♥'; btn.style.background='var(--gold)';
  showToast('Saved to wishlist ♥', 'success');
  renderAll();
}

// ══════════════════════════════════════════
// SELECT MODE
// ══════════════════════════════════════════
function toggleSelectMode(){
  selectMode = !selectMode;
  if(!selectMode){ selected.clear(); updateBulkBar(); renderGrid(); }
  showToast(selectMode ? 'Tap items to select them' : 'Selection mode off');
}
function toggleSelect(id){
  if(!selectMode) return;
  if(selected.has(id)) selected.delete(id);
  else selected.add(id);
  const card = document.getElementById('wc-'+id);
  if(card) card.classList.toggle('selected', selected.has(id));
  updateBulkBar();
}
function updateBulkBar(){
  const bar = document.getElementById('bulkBar');
  document.getElementById('bulkCount').textContent = selected.size;
  bar.classList.toggle('visible', selected.size > 0);
}
function clearSelection(){ selected.clear(); selectMode=false; updateBulkBar(); renderGrid(); }
function bulkAddToCart(){
  selected.forEach(id=>addToCart(id));
  clearSelection();
}
function bulkRemove(){
  selected.forEach(id=>{ wishlistIds=wishlistIds.filter(i=>i!==id); delete wishlistDates[id]; });
  saveWishlist(); saveWishlistDates();
  clearSelection(); renderAll();
  showToast(`${selected.size||'Items'} removed from wishlist`);
}
function bulkMove(){ showToast('Move to list — coming soon'); clearSelection(); }

// ══════════════════════════════════════════
// SORT & FILTER & VIEW
// ══════════════════════════════════════════
function sortWishlist(val){ currentSort=val; renderGrid(); }
function filterByCollection(val,el){
  document.querySelectorAll('.cf-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  currentCollFilter=val;
  renderGrid();
}
function setView(v){
  currentView=v;
  const grid = document.getElementById('wishlistGrid');
  grid.classList.remove('list-view');
  if(v==='list') grid.classList.add('list-view');
  document.getElementById('gridViewBtn').classList.toggle('active',v==='grid');
  document.getElementById('listViewBtn').classList.toggle('active',v==='list');
}

// ══════════════════════════════════════════
// TAB SWITCHING
// ══════════════════════════════════════════
function switchTab(tab, btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('panel-'+tab).classList.add('active');
  btn.classList.add('active');
}

// ══════════════════════════════════════════
// SHARE MODAL
// ══════════════════════════════════════════
function openShareModal(){ document.getElementById('shareModal').classList.add('open'); document.body.style.overflow='hidden'; }
function closeShareModal(){ document.getElementById('shareModal').classList.remove('open'); document.body.style.overflow=''; }
function copyShareLink(){
  navigator.clipboard.writeText(document.getElementById('shareLinkInput').value).then(()=>showToast('Link copied to clipboard!','success')).catch(()=>showToast('Copy the link manually'));
}
function shareVia(platform){
  const msg = `Check out my PRESH HAIRS wishlist — luxury wigs & perfumes! https://preshhairs.com/wishlist/shared?id=presh-xyz-789`;
  const urls={
    WhatsApp:`https://wa.me/?text=${encodeURIComponent(msg)}`,
    'X':`https://twitter.com/intent/tweet?text=${encodeURIComponent(msg)}`,
    Email:`mailto:?subject=My PRESH HAIRS Wishlist&body=${encodeURIComponent(msg)}`,
  };
  if(urls[platform]) window.open(urls[platform],'_blank');
  closeShareModal();
  showToast(`Sharing via ${platform}`);
}
document.getElementById('shareModal').addEventListener('click',e=>{ if(e.target===document.getElementById('shareModal')) closeShareModal(); });

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast show'+(type?' '+type:'');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),3000);
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
renderAll();
</script>
