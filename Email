// PREVIEW
// ══════════════════════════════════════════
function renderPreview(type){
  const frame = document.getElementById('preview-'+type);
  if(!frame) return;
  const doc = frame.contentDocument || frame.contentWindow.document;
  doc.open(); doc.write(getEmailHTML(type)); doc.close();
}
function refreshPreview(type){ renderPreview(type); showToast('Preview refreshed'); }
function setDevice(type, device, btn){
  btn.closest('.preview-device-btns').querySelectorAll('.device-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const frame = document.getElementById('preview-'+type);
  if(frame) frame.style.maxWidth = device==='mobile' ? '375px' : '100%';
}

