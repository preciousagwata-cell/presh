// ══════════════════════════════════════════
// SEND EMAIL (SIMULATED)
// ══════════════════════════════════════════
const emailMeta = {
  'order-confirm': {prefix:'oc', subject:'Your PRESH HAIRS Order is Confirmed ✓', emailField:'oc-email'},
  'shipping':      {prefix:'sh', subject:'Your Order Has Shipped 🚚', emailField:'sh-email'},
  'delivered':     {prefix:'dv', subject:'Your PRESH HAIRS Order Has Been Delivered 📦', emailField:'dv-email'},
  'welcome':       {prefix:'wc', subject:'Welcome to PRESH HAIRS — Your Gift Inside 🎁', emailField:'wc-email'},
  'promo':         {prefix:'pr', subject:'An Exclusive Offer — Just For You ✨', emailField:null},
  'new-arrivals':  {prefix:'na', subject:'New Arrivals Just Dropped at PRESH HAIRS ✦', emailField:null},
  'abandoned':     {prefix:'ab', subject:'Hey — You Left Something Behind 🛒', emailField:'ab-email'},
};
const emailTypeLabels = {
  'order-confirm':'Order Confirmation','shipping':'Shipping Update','delivered':'Order Delivered',
  'welcome':'Welcome Email','promo':'Promo Email','new-arrivals':'New Arrivals','abandoned':'Abandoned Cart'
};

function sendEmail(type){
  const meta = emailMeta[type];
  if(!meta) return;
  const {prefix, subject, emailField} = meta;
  const recipient = emailField ? (document.getElementById(emailField)?.value || 'subscribers') : 'All Subscribers';
  const btn = document.getElementById(prefix+'-btntext');
  const spinner = document.getElementById(prefix+'-spinner');
  const log = document.getElementById(prefix+'-log');

  btn.textContent = 'Sending…';
  if(spinner) spinner.style.display='inline-block';
  log.classList.remove('show','error');

  // Simulate network delay
  setTimeout(()=>{
    const success = Math.random() > 0.05; // 95% success rate simulation
    btn.textContent = success ? '✓ Email Sent!' : '✕ Send Failed';
    if(spinner) spinner.style.display='none';

    if(success){
      log.textContent = `✓ Sent to ${recipient} at ${new Date().toLocaleTimeString()}`;
      log.className = 'send-log show';
      showToast(`Email sent to ${recipient} ✓`, 'success');
      addLog(emailTypeLabels[type], recipient, subject, 'sent');
    } else {
      log.textContent = `✕ Failed — check your email service settings`;
      log.className = 'send-log show error';
      showToast('Send failed — check settings', 'error');
      addLog(emailTypeLabels[type], recipient, subject, 'failed');
    }

    setTimeout(()=>{
      btn.textContent = btn.textContent.includes('✓') ? `Re-send ${emailTypeLabels[type]}` : `Retry ${emailTypeLabels[type]}`;
    }, 3000);
  }, 1400);
}

// ══════════════════════════════════════════
// LOGS
// ══════════════════════════════════════════
function addLog(type, recipient, subject, status){
  sendLogs.unshift({
    id: sendLogs.length+1,
    time: new Date().toLocaleString('en-GB',{hour:'2-digit',minute:'2-digit',day:'numeric',month:'short'}),
    type, recipient, subject, status
  });
  localStorage.setItem('preshEmailLogs', JSON.stringify(sendLogs));
}
function renderLogs(){
  if(!sendLogs.length){
    document.getElementById('logsTableBody').innerHTML=`<tr><td colspan="6" style="text-align:center;padding:3rem;color:var(--text-mid);font-size:0.7rem;">No emails sent yet. Send your first email to see logs here.</td></tr>`;
    return;
  }
  document.getElementById('logsTableBody').innerHTML = sendLogs.map((l,i)=>`
    <tr>
      <td style="color:var(--coffee-light);">#${String(l.id).padStart(3,'0')}</td>
      <td>${l.time}</td>
      <td style="font-weight:600;color:var(--coffee);">${l.type}</td>
      <td>${l.recipient}</td>
      <td style="color:var(--text-dark);">${l.subject}</td>
      <td><span class="log-badge ${l.status}">${l.status}</span></td>
    </tr>`).join('');
}
function clearLogs(){
  if(!confirm('Clear all send logs?')) return;
  sendLogs=[];
  localStorage.removeItem('preshEmailLogs');
  renderLogs();
  showToast('Logs cleared');
}

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
function showToast(msg, type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className='toast show'+(type?' '+type:'');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),3500);
}

