  // ── HERO BG PARALLAX ──
  const heroBg = document.getElementById('heroBg');
  setTimeout(() => heroBg.classList.add('loaded'), 100);
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    heroBg.style.transform = `scale(1) translateY(${y * 0.35}px)`;
  });

  // ── HAMBURGER ──
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => mobileMenu.classList.add('open'));
  document.getElementById('mobileClose').addEventListener('click', () => mobileMenu.classList.remove('open'));
  function closeMobile() { mobileMenu.classList.remove('open'); }

  // ── SCROLL REVEAL ──
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.12 });
  reveals.forEach(r => observer.observe(r));

  // ── TABS ──
  const tabBtns = document.querySelectorAll('.tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.product-grid').forEach(g => g.classList.remove('active'));
      const target = document.getElementById('tab-' + btn.dataset.tab);
      if (target) {
        target.classList.add('active');
        target.querySelectorAll('.reveal').forEach(r => r.classList.add('visible'));
      }
    });
  });

  // ── TESTIMONIAL SLIDER ──
  const track = document.getElementById('testiTrack');
  const cards = track.querySelectorAll('.testi-card');
  const dotsContainer = document.getElementById('testiDots');
  let perView = window.innerWidth <= 768 ? 1 : 3;
  let current = 0;
  const total = Math.ceil(cards.length / perView);

  function buildDots() {
    dotsContainer.innerHTML = '';
    for (let i = 0; i < total; i++) {
      const d = document.createElement('div');
      d.className = 'testi-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(d);
    }
  }
  function goTo(n) {
    current = Math.max(0, Math.min(n, total - 1));
    const cardW = cards[0].offsetWidth + 32;
    track.style.transform = `translateX(-${current * cardW * perView}px)`;
    dotsContainer.querySelectorAll('.testi-dot').forEach((d, i) => d.classList.toggle('active', i === current));
  }
  document.getElementById('testiPrev').addEventListener('click', () => goTo(current - 1));
  document.getElementById('testiNext').addEventListener('click', () => goTo(current + 1));
  buildDots();
  window.addEventListener('resize', () => { perView = window.innerWidth <= 768 ? 1 : 3; buildDots(); goTo(0); });

  // ── NEWSLETTER ──
  function subscribeEmail() {
    const input = document.getElementById('emailInput');
    if (input.value && input.value.includes('@')) {
      input.value = '';
      input.placeholder = '✓ You\'re on the list — welcome to the circle!';
      setTimeout(() => input.placeholder = 'Your email address', 4000);
    }
  }
  document.getElementById('emailInput').addEventListener('keydown', e => { if (e.key === 'Enter') subscribeEmail(); });
</script>
</body>
</html>
