<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PRESH HAIRS — Luxury Wigs & Perfumes</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  :root {
    --coffee: #3B1F0E;
    --coffee-mid: #6B3A20;
    --coffee-light: #A0623A;
    --ivory: #F5EFE6;
    --cream: #EDE4D5;
    --gold: #C9A84C;
    --gold-light: #E2C47A;
    --dark: #1A0E07;
    --text-dark: #2C1A0E;
    --text-mid: #5C3D25;
    --white: #FDFAF6;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--ivory);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--cream); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 1.4rem 5%;
    display: flex; align-items: center; justify-content: space-between;
    background: transparent;
    transition: background 0.5s, backdrop-filter 0.5s, box-shadow 0.5s;
  }
  nav.scrolled {
    background: rgba(250,246,240,0.92);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 30px rgba(59,31,14,0.08);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 600; letter-spacing: 0.18em;
    color: var(--white); text-decoration: none;
    transition: color 0.4s;
  }
  nav.scrolled .nav-logo { color: var(--coffee); }
  .nav-links { display: flex; gap: 2.4rem; list-style: none; }
  .nav-links a {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); text-decoration: none;
    position: relative; padding-bottom: 3px;
    transition: color 0.3s;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1px; background: var(--gold);
    transition: width 0.3s;
  }
  .nav-links a:hover { color: var(--gold-light); }
  .nav-links a:hover::after { width: 100%; }
  nav.scrolled .nav-links a { color: var(--text-mid); }
  nav.scrolled .nav-links a:hover { color: var(--coffee); }
  .nav-cta {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.65rem 1.6rem; border: 1px solid var(--gold);
    background: transparent; color: var(--gold-light); cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    transition: all 0.3s;
  }
  .nav-cta:hover { background: var(--gold); color: var(--dark); }
  nav.scrolled .nav-cta { color: var(--coffee); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span { width: 24px; height: 1.5px; background: var(--white); transition: background 0.4s; }
  nav.scrolled .hamburger span { background: var(--coffee); }

  /* ─── HERO ─── */
  .hero {
    position: relative; height: 100vh; min-height: 700px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; text-align: center;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: url('https://picsum.photos/seed/preshhero/1600/900') center/cover no-repeat;
    transform: scale(1.08);
    transition: transform 8s ease-out;
    filter: brightness(0.38);
  }
  .hero-bg.loaded { transform: scale(1); }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(26,14,7,0.3) 0%, rgba(59,31,14,0.55) 60%, rgba(26,14,7,0.85) 100%);
  }
  .hero-content {
    position: relative; z-index: 2;
    max-width: 860px; padding: 0 5%;
    opacity: 0; transform: translateY(30px);
    animation: heroFade 1.2s 0.4s ease forwards;
  }
  @keyframes heroFade { to { opacity: 1; transform: translateY(0); } }
  .hero-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.4rem;
    display: flex; align-items: center; justify-content: center; gap: 1rem;
  }
  .hero-eyebrow::before, .hero-eyebrow::after {
    content: ''; width: 40px; height: 1px; background: var(--gold); opacity: 0.6;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 6.5rem);
    font-weight: 300; line-height: 1.05;
    color: var(--white); letter-spacing: 0.02em;
    margin-bottom: 1.6rem;
  }
  .hero h1 em { font-style: italic; color: var(--gold-light); }
  .hero p {
    font-size: 0.8rem; letter-spacing: 0.15em; color: rgba(245,239,230,0.75);
    margin-bottom: 3rem; text-transform: uppercase;
  }
  .btn-primary {
    display: inline-block; padding: 1.1rem 3.2rem;
    background: var(--gold); color: var(--dark);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
    text-decoration: none; cursor: pointer; border: none;
    position: relative; overflow: hidden;
    transition: all 0.35s;
  }
  .btn-primary::before {
    content: ''; position: absolute; top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transition: left 0.5s;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 12px 35px rgba(201,168,76,0.35); }
  .btn-primary:hover::before { left: 100%; }
  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: rgba(255,255,255,0.5); font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 1px; height: 50px; background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.4; transform:scaleY(1)} 50%{opacity:1; transform:scaleY(1.1)} }

  /* ─── SECTION UTILS ─── */
  section { padding: 7rem 5%; }
  .section-label {
    font-size: 0.6rem; letter-spacing: 0.4em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.8rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-label::before { content: ''; width: 28px; height: 1px; background: var(--gold); }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 400; line-height: 1.1;
    color: var(--coffee);
  }
  .section-title em { font-style: italic; color: var(--coffee-light); }

  /* ─── REVEAL ─── */
  .reveal {
    opacity: 0; transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* ─── BRAND STORY ─── */
  .brand-story {
    background: var(--white);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0; min-height: 600px; padding: 0;
  }
  .brand-story-image {
    position: relative; overflow: hidden; min-height: 500px;
  }
  .brand-story-image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.8s ease;
  }
  .brand-story-image:hover img { transform: scale(1.04); }
  .brand-story-image::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(59,31,14,0.15) 0%, transparent 60%);
  }
  .brand-story-content {
    padding: 6rem 5rem;
    display: flex; flex-direction: column; justify-content: center;
    background: var(--white);
  }
  .brand-story-content .section-title { margin-bottom: 1.8rem; }
  .brand-story-content p {
    font-size: 0.85rem; line-height: 1.9; color: var(--text-mid);
    margin-bottom: 1.2rem; font-weight: 300;
  }
  .brand-story-content .btn-outline {
    display: inline-block; margin-top: 1.5rem;
    padding: 0.9rem 2.4rem; border: 1px solid var(--coffee);
    font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--coffee); text-decoration: none;
    transition: all 0.3s; align-self: flex-start;
  }
  .brand-story-content .btn-outline:hover {
    background: var(--coffee); color: var(--ivory);
  }
  .gold-divider {
    width: 60px; height: 2px;
    background: linear-gradient(to right, var(--gold), var(--gold-light));
    margin-bottom: 2rem;
  }

  /* ─── WIG COLLECTIONS ─── */
  .wigs { background: var(--ivory); }
  .wigs .section-header {
    text-align: center; margin-bottom: 4rem;
  }
  .wigs .section-label { justify-content: center; }
  .wigs .section-label::before { display: none; }
  .wigs .section-label::after { content: ''; width: 28px; height: 1px; background: var(--gold); }
  .collection-tabs {
    display: flex; justify-content: center; gap: 0;
    margin-bottom: 3.5rem; flex-wrap: wrap;
    border-bottom: 1px solid rgba(59,31,14,0.12);
  }
  .tab-btn {
    padding: 0.75rem 1.8rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
    border: none; background: transparent; color: var(--text-mid); cursor: pointer;
    position: relative; transition: color 0.3s;
  }
  .tab-btn::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
    height: 2px; background: var(--gold); transform: scaleX(0); transition: transform 0.3s;
  }
  .tab-btn.active { color: var(--coffee); font-weight: 600; }
  .tab-btn.active::after, .tab-btn:hover::after { transform: scaleX(1); }
  .product-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem;
    display: none;
  }
  .product-grid.active { display: grid; }
  .product-card {
    background: var(--white); position: relative; overflow: hidden;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    cursor: pointer;
  }
  .product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(59,31,14,0.15); }
  .product-image {
    position: relative; overflow: hidden;
    aspect-ratio: 3/4;
  }
  .product-image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .product-card:hover .product-image img { transform: scale(1.08); }
  .product-badge {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.35rem 0.8rem; background: var(--gold); color: var(--dark);
  }
  .product-overlay {
    position: absolute; inset: 0;
    background: rgba(26,14,7,0.55);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.4s;
  }
  .product-card:hover .product-overlay { opacity: 1; }
  .product-overlay a {
    padding: 0.75rem 2rem;
    border: 1px solid var(--gold-light); color: var(--white);
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    text-decoration: none; transition: all 0.3s;
  }
  .product-overlay a:hover { background: var(--gold); color: var(--dark); border-color: var(--gold); }
  .product-info { padding: 1.4rem; }
  .product-info h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem; font-weight: 500; color: var(--coffee);
    margin-bottom: 0.3rem;
  }
  .product-info .sub {
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--coffee-light); margin-bottom: 0.8rem;
  }
  .product-info .price {
    font-size: 0.85rem; font-weight: 600; color: var(--coffee);
    letter-spacing: 0.05em;
  }
  .product-info .price span {
    font-size: 0.7rem; color: var(--coffee-light); text-decoration: line-through; margin-left: 0.5rem; font-weight: 300;
  }

  /* ─── PERFUMES ─── */
  .perfumes {
    background: var(--dark);
    position: relative; overflow: hidden; padding: 8rem 5%;
  }
  .perfumes::before {
    content: ''; position: absolute; inset: 0;
    background: url('https://picsum.photos/seed/perfumebg/1600/900') center/cover no-repeat;
    opacity: 0.07;
  }
  .perfumes .section-header { text-align: center; margin-bottom: 4.5rem; position: relative; }
  .perfumes .section-label { color: var(--gold); justify-content: center; }
  .perfumes .section-label::before, .perfumes .section-label::after { background: var(--gold); }
  .perfumes .section-label::after { content: ''; width: 28px; height: 1px; background: var(--gold); }
  .perfumes .section-label::before { display: inline-block; }
  .perfumes .section-title { color: var(--ivory); }
  .perfumes .section-title em { color: var(--gold-light); }
  .perfumes .section-subtitle {
    font-size: 0.78rem; color: rgba(245,239,230,0.5); margin-top: 1rem;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .perfume-grid {
    display: grid; grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.5rem; position: relative;
  }
  .perfume-card {
    position: relative; overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,168,76,0.18);
    transition: border-color 0.4s, transform 0.4s, box-shadow 0.4s;
    cursor: pointer;
  }
  .perfume-card:hover {
    border-color: rgba(201,168,76,0.5);
    transform: translateY(-6px);
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
  }
  .perfume-card.featured { grid-row: span 1; }
  .perfume-card-image {
    overflow: hidden; aspect-ratio: 3/4;
  }
  .perfume-card.featured .perfume-card-image { aspect-ratio: 2/2.5; }
  .perfume-card-image img {
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(0.7) brightness(0.75);
    transition: filter 0.6s, transform 0.6s;
  }
  .perfume-card:hover .perfume-card-image img {
    filter: saturate(0.9) brightness(0.85);
    transform: scale(1.05);
  }
  .perfume-card-body { padding: 1.8rem; }
  .perfume-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.7rem; color: var(--gold); letter-spacing: 0.3em;
    margin-bottom: 0.5rem;
  }
  .perfume-card-body h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 400; color: var(--ivory);
    line-height: 1.15; margin-bottom: 0.6rem;
  }
  .perfume-card.featured .perfume-card-body h3 { font-size: 2rem; }
  .perfume-notes {
    font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(245,239,230,0.45); line-height: 1.8;
  }
  .perfume-card-body .price-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 1.5rem; padding-top: 1.2rem;
    border-top: 1px solid rgba(201,168,76,0.15);
  }
  .perfume-price {
    font-size: 1rem; color: var(--gold); font-weight: 500;
    font-family: 'Cormorant Garamond', serif;
  }
  .perfume-cta {
    font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.5rem 1.2rem; border: 1px solid rgba(201,168,76,0.4);
    color: var(--gold-light); background: transparent;
    font-family: 'Montserrat', sans-serif; cursor: pointer;
    transition: all 0.3s;
  }
  .perfume-cta:hover { background: var(--gold); color: var(--dark); border-color: var(--gold); }

  /* ─── WHY US ─── */
  .why-us { background: var(--cream); text-align: center; }
  .why-us .section-header { margin-bottom: 4rem; }
  .why-us .section-label { justify-content: center; }
  .why-us .section-label::before { display: none; }
  .why-us .section-label::after { content: ''; width: 28px; height: 1px; background: var(--gold); }
  .features-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 2.5rem;
  }
  .feature-card {
    padding: 2.5rem 1.5rem;
    background: var(--white);
    border-bottom: 2px solid transparent;
    transition: border-color 0.4s, transform 0.4s, box-shadow 0.4s;
  }
  .feature-card:hover {
    border-bottom-color: var(--gold);
    transform: translateY(-6px);
    box-shadow: 0 15px 40px rgba(59,31,14,0.1);
  }
  .feature-icon {
    font-size: 2rem; margin-bottom: 1.4rem;
    display: block; filter: sepia(1) saturate(2) hue-rotate(5deg);
  }
  .feature-card h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: var(--coffee); margin-bottom: 0.8rem;
  }
  .feature-card p {
    font-size: 0.72rem; line-height: 1.8; color: var(--text-mid); font-weight: 300;
  }

  /* ─── TESTIMONIALS ─── */
  .testimonials { background: var(--coffee); overflow: hidden; position: relative; }
  .testimonials::before {
    content: '"'; position: absolute; top: -2rem; left: 3%;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20rem; color: rgba(255,255,255,0.04); line-height: 1; pointer-events: none;
  }
  .testimonials .section-header { margin-bottom: 4rem; }
  .testimonials .section-label { color: var(--gold-light); }
  .testimonials .section-label::before { background: var(--gold-light); }
  .testimonials .section-title { color: var(--ivory); }
  .testimonials .section-title em { color: var(--gold-light); }
  .testi-track-wrap { overflow: hidden; }
  .testi-track {
    display: flex; gap: 2rem;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .testi-card {
    flex: 0 0 calc(33.333% - 1.35rem);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 3rem 2.5rem; position: relative;
  }
  .testi-stars { color: var(--gold); font-size: 0.8rem; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
  .testi-card blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem; font-style: italic; font-weight: 300;
    line-height: 1.7; color: rgba(245,239,230,0.9);
    margin-bottom: 2rem;
  }
  .testi-author {
    display: flex; align-items: center; gap: 1rem;
  }
  .testi-avatar {
    width: 44px; height: 44px; border-radius: 50%; overflow: hidden;
    border: 2px solid rgba(201,168,76,0.4);
  }
  .testi-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .testi-name { font-size: 0.7rem; font-weight: 600; color: var(--ivory); letter-spacing: 0.1em; }
  .testi-role { font-size: 0.6rem; color: rgba(245,239,230,0.45); letter-spacing: 0.1em; text-transform: uppercase; }
  .testi-controls {
    display: flex; align-items: center; gap: 1.5rem; margin-top: 3rem;
  }
  .testi-btn {
    width: 46px; height: 46px; border: 1px solid rgba(201,168,76,0.4);
    background: transparent; color: var(--gold); cursor: pointer; font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s;
  }
  .testi-btn:hover { background: var(--gold); color: var(--dark); }
  .testi-dots { display: flex; gap: 0.6rem; }
  .testi-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(201,168,76,0.35); cursor: pointer; transition: background 0.3s, transform 0.3s;
  }
  .testi-dot.active { background: var(--gold); transform: scale(1.4); }

  /* ─── NEWSLETTER ─── */
  .newsletter {
    background: var(--ivory);
    text-align: center; padding: 7rem 5%;
    position: relative; overflow: hidden;
  }
  .newsletter::before {
    content: ''; position: absolute;
    top: -100px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .newsletter .section-title { margin-bottom: 1rem; }
  .newsletter p {
    font-size: 0.8rem; color: var(--text-mid); letter-spacing: 0.12em;
    text-transform: uppercase; margin-bottom: 2.5rem;
  }
  .newsletter-form {
    display: flex; max-width: 500px; margin: 0 auto;
    border: 1px solid rgba(59,31,14,0.2);
    overflow: hidden;
    transition: box-shadow 0.3s;
  }
  .newsletter-form:focus-within {
    box-shadow: 0 0 0 2px rgba(201,168,76,0.4);
  }
  .newsletter-form input {
    flex: 1; padding: 1.1rem 1.5rem;
    border: none; outline: none; background: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem; color: var(--text-dark);
    letter-spacing: 0.05em;
  }
  .newsletter-form input::placeholder { color: rgba(92,61,37,0.4); }
  .newsletter-form button {
    padding: 1.1rem 2rem; background: var(--coffee);
    border: none; color: var(--ivory); cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
    transition: background 0.3s;
  }
