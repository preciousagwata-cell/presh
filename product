<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PRESH HAIRS — Product</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --coffee:#3B1F0E; --coffee-mid:#6B3A20; --coffee-light:#A0623A;
    --ivory:#F5EFE6; --cream:#EDE4D5; --gold:#C9A84C; --gold-light:#E2C47A;
    --dark:#1A0E07; --text-dark:#2C1A0E; --text-mid:#5C3D25; --white:#FDFAF6;
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{font-family:'Montserrat',sans-serif;background:var(--ivory);color:var(--text-dark);overflow-x:hidden;}
  ::-webkit-scrollbar{width:6px;} ::-webkit-scrollbar-track{background:var(--cream);} ::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px;}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.4rem 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(250,246,240,0.95);backdrop-filter:blur(12px);box-shadow:0 2px 30px rgba(59,31,14,0.08);}
  .nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;letter-spacing:0.18em;color:var(--coffee);text-decoration:none;}
  .nav-links{display:flex;gap:2.4rem;list-style:none;}
  .nav-links a{font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-mid);text-decoration:none;position:relative;padding-bottom:3px;transition:color 0.3s;}
  .nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--gold);transition:width 0.3s;}
  .nav-links a:hover{color:var(--coffee);} .nav-links a:hover::after{width:100%;}
  .nav-cart{position:relative;cursor:pointer;background:var(--coffee);color:var(--ivory);border:none;padding:0.65rem 1.4rem;font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;display:flex;align-items:center;gap:0.6rem;transition:background 0.3s;}
  .nav-cart:hover{background:var(--coffee-mid);}
  .nav-cart-badge{background:var(--gold);color:var(--dark);font-size:0.5rem;font-weight:700;padding:1px 5px;border-radius:2px;}

  /* BREADCRUMB */
  .breadcrumb-bar{margin-top:72px;padding:1rem 5%;background:var(--white);border-bottom:1px solid rgba(59,31,14,0.08);display:flex;align-items:center;gap:0.6rem;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-mid);}
  .breadcrumb-bar a{color:var(--coffee-light);text-decoration:none;transition:color 0.3s;} .breadcrumb-bar a:hover{color:var(--coffee);}
  .breadcrumb-bar span{color:rgba(59,31,14,0.3);}

  /* PRODUCT LAYOUT */
  .product-page{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:80vh;}

  /* GALLERY */
  .gallery{padding:3rem 4rem 3rem 5%;background:var(--white);position:sticky;top:72px;height:fit-content;}
  .gallery-main{position:relative;overflow:hidden;aspect-ratio:3/4;margin-bottom:1rem;cursor:zoom-in;}
  .gallery-main img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease;}
  .gallery-main:hover img{transform:scale(1.06);}
  .gallery-badge{position:absolute;top:1rem;left:1rem;font-size:0.52rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.3rem 0.8rem;background:var(--gold);color:var(--dark);}
  .gallery-thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:0.6rem;}
  .thumb{aspect-ratio:1;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:border-color 0.25s;}
  .thumb.active,.thumb:hover{border-color:var(--gold);}
  .thumb img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s;}
  .thumb:hover img{transform:scale(1.08);}

  /* PRODUCT INFO */
  .product-details{padding:3rem 5% 3rem 4rem;background:var(--ivory);}
  .p-collection{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem;}
  .p-name{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:400;color:var(--coffee);line-height:1.1;margin-bottom:0.8rem;}
  .p-rating-row{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;}
  .p-stars{color:var(--gold);font-size:0.85rem;letter-spacing:0.05em;}
  .p-review-count{font-size:0.6rem;color:var(--text-mid);letter-spacing:0.1em;border-left:1px solid rgba(59,31,14,0.15);padding-left:1rem;}
  .p-price-block{display:flex;align-items:baseline;gap:1rem;margin-bottom:2rem;padding:1.2rem 0;border-top:1px solid rgba(59,31,14,0.1);border-bottom:1px solid rgba(59,31,14,0.1);}
  .p-price{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:500;color:var(--coffee);}
  .p-old-price{font-size:1.1rem;color:var(--coffee-light);text-decoration:line-through;font-weight:300;}
  .p-save{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;background:rgba(201,168,76,0.15);color:var(--coffee-mid);padding:0.3rem 0.7rem;}

  /* OPTIONS */
  .option-block{margin-bottom:1.8rem;}
  .option-label{font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-mid);margin-bottom:0.8rem;display:flex;align-items:center;gap:0.6rem;}
  .option-label strong{color:var(--coffee);}
  .size-grid{display:flex;flex-wrap:wrap;gap:0.5rem;}
  .size-opt{padding:0.55rem 1.1rem;border:1px solid rgba(59,31,14,0.2);background:transparent;font-family:'Montserrat',sans-serif;font-size:0.65rem;color:var(--text-mid);cursor:pointer;transition:all 0.25s;}
  .size-opt:hover,.size-opt.active{background:var(--coffee);color:var(--ivory);border-color:var(--coffee);}
  .size-opt.unavailable{opacity:0.35;cursor:not-allowed;text-decoration:line-through;}
  .color-grid{display:flex;gap:0.7rem;flex-wrap:wrap;}
  .color-opt{width:32px;height:32px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all 0.25s;position:relative;}
  .color-opt:hover,.color-opt.active{border-color:var(--gold);transform:scale(1.1);}
  .color-opt .color-label{position:absolute;bottom:-1.4rem;left:50%;transform:translateX(-50%);font-size:0.5rem;white-space:nowrap;color:var(--text-mid);letter-spacing:0.1em;opacity:0;transition:opacity 0.2s;}
  .color-opt:hover .color-label{opacity:1;}

  /* QTY */
  .qty-row{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;}
  .qty-ctrl{display:flex;align-items:center;border:1px solid rgba(59,31,14,0.2);}
  .qty-btn{width:38px;height:38px;border:none;background:transparent;font-size:1.1rem;color:var(--coffee);cursor:pointer;transition:background 0.2s;}
  .qty-btn:hover{background:var(--cream);}
  .qty-num{width:48px;text-align:center;font-size:0.85rem;font-weight:600;color:var(--coffee);border:none;background:transparent;outline:none;}
  .qty-label{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-mid);}

  /* CTA BUTTONS */
  .cta-stack{display:flex;flex-direction:column;gap:0.8rem;margin-bottom:2rem;}
  .btn-add-cart{padding:1.2rem;background:var(--coffee);color:var(--ivory);border:none;font-family:'Montserrat',sans-serif;font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:0.8rem;}
  .btn-add-cart:hover{background:var(--coffee-mid);}
  .btn-add-cart.added{background:#1e7c1e;}
  .btn-buy-now{padding:1.2rem;background:var(--gold);color:var(--dark);border:none;font-family:'Montserrat',sans-serif;font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;}
  .btn-buy-now:hover{background:var(--gold-light);}
  .btn-wishlist{padding:1rem;background:transparent;border:1px solid rgba(59,31,14,0.2);color:var(--coffee);font-family:'Montserrat',sans-serif;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:0.6rem;}
  .btn-wishlist:hover{background:var(--cream);border-color:var(--coffee);}

  /* PERKS */
  .perks-row{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid rgba(59,31,14,0.1);margin-bottom:2rem;}
  .perk{padding:1rem 0.8rem;text-align:center;border-right:1px solid rgba(59,31,14,0.1);}
  .perk:last-child{border-right:none;}
  .perk-icon{font-size:1.2rem;margin-bottom:0.4rem;display:block;}
  .perk-text{font-size:0.55rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-mid);line-height:1.5;}

  /* ACCORDION */
  .accordion{border-top:1px solid rgba(59,31,14,0.1);}
  .acc-item{border-bottom:1px solid rgba(59,31,14,0.1);}
  .acc-header{width:100%;padding:1.2rem 0;display:flex;align-items:center;justify-content:space-between;background:transparent;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--coffee);transition:color 0.3s;}
  .acc-header:hover{color:var(--coffee-mid);}
  .acc-icon{font-size:1rem;transition:transform 0.3s;color:var(--gold);}
  .acc-item.open .acc-icon{transform:rotate(45deg);}
  .acc-body{max-height:0;overflow:hidden;transition:max-height 0.4s ease;}
  .acc-item.open .acc-body{max-height:400px;}
  .acc-content{padding:0 0 1.5rem;font-size:0.72rem;line-height:1.9;color:var(--text-mid);font-weight:300;}
  .acc-content ul{padding-left:1.2rem;margin-top:0.5rem;}
  .acc-content li{margin-bottom:0.4rem;}

  /* REVIEWS SECTION */
  .reviews-section{padding:5rem 5%;background:var(--white);}
  .reviews-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;flex-wrap:wrap;gap:1rem;}
  .reviews-header h2{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:400;color:var(--coffee);}
  .rating-summary{display:flex;align-items:center;gap:2rem;flex-wrap:wrap;}
  .big-rating{font-family:'Cormorant Garamond',serif;font-size:4rem;color:var(--coffee);line-height:1;}
  .rating-bars{display:flex;flex-direction:column;gap:0.4rem;}
  .rating-bar-row{display:flex;align-items:center;gap:0.8rem;font-size:0.6rem;color:var(--text-mid);}
  .rating-bar-track{width:120px;height:4px;background:rgba(59,31,14,0.1);border-radius:2px;overflow:hidden;}
  .rating-bar-fill{height:100%;background:var(--gold);border-radius:2px;}
  .reviews-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;}
  .review-card{padding:2rem;background:var(--ivory);border-left:3px solid var(--gold);}
  .review-top{display:flex;align-items:center;gap:1rem;margin-bottom:1rem;}
  .review-avatar{width:42px;height:42px;border-radius:50%;overflow:hidden;border:2px solid rgba(201,168,76,0.3);}
  .review-avatar img{width:100%;height:100%;object-fit:cover;}
  .review-name{font-size:0.72rem;font-weight:600;color:var(--coffee);}
  .review-date{font-size:0.58rem;color:var(--coffee-light);letter-spacing:0.1em;}
  .review-stars{color:var(--gold);font-size:0.7rem;margin-bottom:0.8rem;}
  .review-text{font-size:0.72rem;line-height:1.8;color:var(--text-mid);font-weight:300;font-style:italic;}

  /* RELATED PRODUCTS */
  .related-section{padding:5rem 5%;background:var(--ivory);}
  .related-section h2{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:400;color:var(--coffee);margin-bottom:0.5rem;}
  .section-sub{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:2.5rem;}
  .related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
  .related-card{background:var(--white);cursor:pointer;transition:transform 0.3s,box-shadow 0.3s;text-decoration:none;}
  .related-card:hover{transform:translateY(-6px);box-shadow:0 15px 40px rgba(59,31,14,0.12);}
  .related-img{aspect-ratio:3/4;overflow:hidden;}
  .related-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s;}
  .related-card:hover .related-img img{transform:scale(1.06);}
  .related-info{padding:1rem;}
  .related-info h4{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--coffee);margin-bottom:0.2rem;}
  .related-info .price{font-size:0.8rem;font-weight:600;color:var(--coffee);}

  /* CART PANEL */
  .cart-panel{position:fixed;top:0;right:0;bottom:0;width:380px;background:var(--white);z-index:2000;display:flex;flex-direction:column;transform:translateX(100%);transition:transform 0.45s cubic-bezier(0.77,0,0.175,1);box-shadow:-10px 0 40px rgba(26,14,7,0.15);}
  .cart-panel.open{transform:translateX(0);}
  .cart-overlay{position:fixed;inset:0;background:rgba(26,14,7,0.5);z-index:1999;opacity:0;pointer-events:none;transition:opacity 0.4s;}
  .cart-overlay.open{opacity:1;pointer-events:all;}
  .cart-panel-head{padding:1.5rem 2rem;border-bottom:1px solid rgba(59,31,14,0.1);display:flex;align-items:center;justify-content:space-between;}
  .cart-panel-head h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--coffee);}
  .cart-close{background:none;border:none;font-size:1.2rem;color:var(--coffee-mid);cursor:pointer;padding:0.3rem;}
  .cart-items{flex:1;overflow-y:auto;padding:1.5rem 2rem;}
  .cart-empty{text-align:center;padding:4rem 1rem;}
  .cart-empty p{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--coffee-light);}
  .cart-empty small{font-size:0.65rem;color:var(--text-mid);letter-spacing:0.1em;text-transform:uppercase;}
  .cart-item{display:grid;grid-template-columns:80px 1fr auto;gap:1rem;padding:1rem 0;border-bottom:1px solid rgba(59,31,14,0.08);align-items:center;}
  .cart-item-img{width:80px;height:100px;object-fit:cover;}
  .cart-item-name{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--coffee);margin-bottom:0.2rem;}
  .cart-item-sub{font-size:0.58rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--coffee-light);}
  .cart-item-price{font-size:0.8rem;font-weight:600;color:var(--coffee);margin-top:0.4rem;}
  .cart-item-remove{background:none;border:none;color:var(--coffee-light);cursor:pointer;font-size:1rem;padding:0.3rem;transition:color 0.2s;}
  .cart-item-remove:hover{color:darkred;}
  .cart-footer{padding:1.5rem 2rem;border-top:1px solid rgba(59,31,14,0.1);}
  .cart-subtotal{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
  .cart-subtotal span{font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-mid);}
  .cart-subtotal strong{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--coffee);}
  .btn-checkout{width:100%;padding:1.1rem;background:var(--gold);color:var(--dark);border:none;font-family:'Montserrat',sans-serif;font-size:0.65rem;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;margin-bottom:0.7rem;transition:all 0.3s;}
  .btn-checkout:hover{background:var(--gold-light);}
  .btn-view-cart{width:100%;padding:1rem;background:transparent;border:1px solid rgba(59,31,14,0.2);color:var(--coffee);font-family:'Montserrat',sans-serif;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;text-decoration:none;display:block;text-align:center;}
  .btn-view-cart:hover{background:var(--cream);}

  @media(max-width:900px){
    .product-page{grid-template-columns:1fr;}
    .gallery{position:static;padding:2rem 5% 1rem;}
    .product-details{padding:1.5rem 5% 3rem;}
    .related-grid{grid-template-columns:repeat(2,1fr);}
    .reviews-grid{grid-template-columns:1fr;}
    .cart-panel{width:100%;}
  }
  @media(max-width:600px){
    .nav-links{display:none;}
    .related-grid{grid-template-columns:repeat(2,1fr);}
    .gallery-thumbs{grid-template-columns:repeat(4,1fr);}
    .perks-row{grid-template-columns:1fr;}
    .perk{border-right:none;border-bottom:1px solid rgba(59,31,14,0.1);}
    .perk:last-child{border-bottom:none;}
  }
</style>
</head>
<body>

<!-- CART OVERLAY -->
<div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>

<!-- CART PANEL -->
<div class="cart-panel" id="cartPanel">
  <div class="cart-panel-head">
    <h3>Your Cart (<span id="cartCountPanel">0</span>)</h3>
    <button class="cart-close" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-items" id="cartItemsList">
    <div class="cart-empty" id="cartEmpty">
      <p>Your cart is empty</p><br/>
      <small>Add something beautiful</small>
    </div>
  </div>
  <div class="cart-footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <strong id="cartSubtotal">₦0</strong>
    </div>
    <button class="btn-checkout" onclick="window.location.href='cart.html'">Proceed to Checkout →</button>
    <a href="cart.html" class="btn-view-cart">View Full Cart</a>
  </div>
</div>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="preshhairs.html">PRESH HAIRS</a>
  <ul class="nav-links">
    <li><a href="preshhairs.html#story">Our Story</a></li>
    <li><a href="collection.html">Collections</a></li>
    <li><a href="preshhairs.html#perfumes">Perfumes</a></li>
    <li><a href="preshhairs.html#testimonials">Reviews</a></li>
  </ul>
  <button class="nav-cart" onclick="openCart()">
    🛍 Cart <span class="nav-cart-badge" id="navCartBadge">0</span>
  </button>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
  <a href="preshhairs.html">Home</a>
  <span>/</span>
  <a href="collection.html">Collections</a>
  <span>/</span>
  <a href="collection.html?collection=professional" id="bcCollection">9 to 5 Professional</a>
  <span>/</span>
  <span id="bcProduct">Product</span>
</div>

<!-- PRODUCT LAYOUT -->
<div class="product-page">

  <!-- GALLERY -->
  <div class="gallery">
    <div class="gallery-main" id="galleryMain">
      <img src="" id="mainImg" alt="Product image"/>
      <span class="gallery-badge" id="galleryBadge" style="display:none;"></span>
    </div>
    <div class="gallery-thumbs" id="galleryThumbs"></div>
  </div>

  <!-- DETAILS -->
  <div class="product-details">
    <p class="p-collection" id="pCollection"></p>
    <h1 class="p-name" id="pName"></h1>
    <div class="p-rating-row">
      <span class="p-stars" id="pStars"></span>
      <span class="p-review-count">42 verified reviews</span>
    </div>

    <div class="p-price-block">
      <span class="p-price" id="pPrice"></span>
      <span class="p-old-price" id="pOldPrice" style="display:none;"></span>
      <span class="p-save" id="pSave" style="display:none;"></span>
    </div>

    <!-- LENGTH -->
    <div class="option-block">
      <p class="option-label">Length — <strong id="selectedLength">12"</strong></p>
      <div class="size-grid">
        <button class="size-opt" onclick="selectSize(this,'10&quot;')">10"</button>
        <button class="size-opt active" onclick="selectSize(this,'12&quot;')">12"</button>
        <button class="size-opt" onclick="selectSize(this,'14&quot;')">14"</button>
        <button class="size-opt" onclick="selectSize(this,'16&quot;')">16"</button>
        <button class="size-opt" onclick="selectSize(this,'18&quot;')">18"</button>
        <button class="size-opt" onclick="selectSize(this,'20&quot;')">20"</button>
        <button class="size-opt unavailable" disabled>22"</button>
        <button class="size-opt unavailable" disabled>24"</button>
      </div>
    </div>

    <!-- COLOUR -->
    <div class="option-block">
      <p class="option-label">Colour — <strong id="selectedColor">Jet Black</strong></p>
      <div class="color-grid">
        <div class="color-opt active" style="background:#1a1a1a;" onclick="selectColor(this,'Jet Black')"><span class="color-label">Jet Black</span></div>
        <div class="color-opt" style="background:#3d2b1f;" onclick="selectColor(this,'Dark Brown')"><span class="color-label">Dark Brown</span></div>
        <div class="color-opt" style="background:#8B5E3C;" onclick="selectColor(this,'Warm Brown')"><span class="color-label">Warm Brown</span></div>
        <div class="color-opt" style="background:#C9A84C;" onclick="selectColor(this,'Blonde')"><span class="color-label">Blonde</span></div>
        <div class="color-opt" style="background:#8B0000;" onclick="selectColor(this,'Burgundy')"><span class="color-label">Burgundy</span></div>
      </div>
    </div>

    <!-- QTY -->
    <div class="qty-row">
      <span class="qty-label">Quantity</span>
      <div class="qty-ctrl">
        <button class="qty-btn" onclick="changeQty(-1)">−</button>
        <input class="qty-num" type="number" id="qtyInput" value="1" min="1" max="10" readonly/>
        <button class="qty-btn" onclick="changeQty(1)">+</button>
      </div>
    </div>

    <!-- CTA -->
    <div class="cta-stack">
      <button class="btn-add-cart" id="addCartBtn" onclick="handleAddToCart()">
        <span id="addCartText">Add to Cart</span>
