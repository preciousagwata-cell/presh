<script>
const PRODUCTS = [
  {id:1,collection:'professional',name:'Executive Sleek Bob',sub:'9 to 5 Professional',price:85000,oldPrice:110000,badge:'Bestseller',rating:'★★★★★',desc:'A power wig designed for the boardroom. Silky straight, lace front, pre-plucked hairline with baby hairs. Lightweight cap for all-day wear. The cap construction features an adjustable strap and breathable mesh — ensuring comfort through the longest workday.',tags:['Lace Front','Silky Straight','Pre-Plucked'],img:'https://picsum.photos/seed/pw1/480/640'},
  {id:2,collection:'professional',name:'Power Lace Front',sub:'9 to 5 Professional',price:120000,oldPrice:null,badge:'New',rating:'★★★★★',desc:'A commanding full lace wig with a natural melt. Available in jet black and dark brown. Perfect for high-stakes meetings and presentations. HD lace blends seamlessly into all skin tones.',tags:['Full Lace','Natural Hairline','HD Lace'],img:'https://picsum.photos/seed/pw2/480/640'},
  {id:3,collection:'professional',name:'Boardroom Silk Press',sub:'9 to 5 Professional',price:95000,oldPrice:null,badge:null,rating:'★★★★☆',desc:'Mimics a perfect silk press. Heat-resistant fibres that hold styling beautifully. Adjustable strap cap for secure fit throughout demanding days.',tags:['Silk Press','Heat-Resistant','Adjustable Cap'],img:'https://picsum.photos/seed/pw3/480/640'},
  {id:4,collection:'professional',name:'Corporate Closure Queen',sub:'9 to 5 Professional',price:78000,oldPrice:95000,badge:'Sale',rating:'★★★★★',desc:'A sleek 4x4 closure wig with a clean centre part. Effortlessly polished for every professional setting.',tags:['Closure','Centre Part','Shine'],img:'https://picsum.photos/seed/pw4/480/640'},
  {id:5,collection:'professional',name:'Velvet Straight 180%',sub:'9 to 5 Professional',price:140000,oldPrice:null,badge:'Premium',rating:'★★★★★',desc:'Ultra-dense 180% density lace front with a velvet-like feel. The ultimate statement piece for women who command any room.',tags:['180% Density','Velvet Texture','Statement'],img:'https://picsum.photos/seed/pw5/480/640'},
  {id:6,collection:'professional',name:'Midnight Bob Lace',sub:'9 to 5 Professional',price:92000,oldPrice:null,badge:null,rating:'★★★★☆',desc:'A chic blunt bob that grazes the shoulders. Jet black with a subtle gloss finish. Clean, sharp, and utterly professional.',tags:['Bob','Blunt Cut','Jet Black'],img:'https://picsum.photos/seed/pw6/480/640'},
  {id:7,collection:'student',name:'Campus Chic Curls',sub:'Students Collection',price:45000,oldPrice:null,badge:'Popular',rating:'★★★★★',desc:'Bouncy natural curls that go from lecture hall to late-night hangout.',tags:['Curly','Lightweight','Natural Look'],img:'https://picsum.photos/seed/sw1/480/640'},
  {id:8,collection:'student',name:'Study Hall Glam',sub:'Students Collection',price:55000,oldPrice:65000,badge:'Sale',rating:'★★★★☆',desc:'Sleek, straight, and budget-friendly luxury.',tags:['Straight','Budget Luxury','Deep Wave'],img:'https://picsum.photos/seed/sw2/480/640'},
  {id:9,collection:'student',name:'Effortless Wave Unit',sub:'Students Collection',price:38000,oldPrice:null,badge:null,rating:'★★★☆☆',desc:'Beachy loose waves that require zero styling effort.',tags:['Loose Wave','No Styling','Easy Wear'],img:'https://picsum.photos/seed/sw3/480/640'},
  {id:10,collection:'student',name:'Weekend Kinks',sub:'Students Collection',price:32000,oldPrice:null,badge:'New',rating:'★★★★★',desc:'Natural kinky coils that celebrate your roots.',tags:['Kinky','Natural','Protective'],img:'https://picsum.photos/seed/sw4/480/640'},
  {id:11,collection:'errand',name:'On-The-Go Ponytail',sub:'Errand & Gym',price:28000,oldPrice:null,badge:null,rating:'★★★★☆',desc:'High ponytail unit that stays put through runs and errands.',tags:['Ponytail','Secure Grip','Sporty'],img:'https://picsum.photos/seed/ew1/480/640'},
  {id:12,collection:'errand',name:'Sweat-Proof Braid Unit',sub:'Errand & Gym',price:32000,oldPrice:null,badge:'New',rating:'★★★★★',desc:'Box braid wig unit engineered for active women.',tags:['Braids','Moisture-Wick','Active'],img:'https://picsum.photos/seed/ew2/480/640'},
  {id:13,collection:'errand',name:'Active Kinks & Coils',sub:'Errand & Gym',price:22000,oldPrice:null,badge:null,rating:'★★★★☆',desc:'Afro kinks unit perfect for high-intensity workouts.',tags:['Afro','Breathable','Gym'],img:'https://picsum.photos/seed/ew3/480/640'},
  {id:14,collection:'errand',name:'Quick-Fix Twist Out',sub:'Errand & Gym',price:25000,oldPrice:30000,badge:'Sale',rating:'★★★★☆',desc:'A twist-out style wig for when you need to dash out.',tags:['Twist Out','Quick Wear','Effortless'],img:'https://picsum.photos/seed/ew4/480/640'},
  {id:15,collection:'raw',name:'Vietnamese Raw Bundle',sub:'Raw Hairs',price:150000,oldPrice:null,badge:'Premium',rating:'★★★★★',desc:'Single-donor Vietnamese raw hair — silky, strong, and gloriously thick.',tags:['Single Donor','Dyeable','Bleachable'],img:'https://picsum.photos/seed/rw1/480/640'},
  {id:16,collection:'raw',name:'Cambodian Wavy Raw',sub:'Raw Hairs',price:175000,oldPrice:null,badge:'Premium',rating:'★★★★★',desc:'Authentic Cambodian wavy texture that tightens beautifully in water.',tags:['Cambodian','Wavy','Water-Friendly'],img:'https://picsum.photos/seed/rw2/480/640'},
  {id:17,collection:'raw',name:'Burmese Straight Raw',sub:'Raw Hairs',price:160000,oldPrice:195000,badge:'Sale',rating:'★★★★☆',desc:'Luxurious Burmese straight raw hair with natural shine.',tags:['Burmese','Straight','Dense'],img:'https://picsum.photos/seed/rw3/480/640'},
  {id:18,collection:'raw',name:'Indian Loose Deep',sub:'Raw Hairs',price:145000,oldPrice:null,badge:'New',rating:'★★★★★',desc:'Natural Indian loose deep wave raw bundles.',tags:['Indian','Loose Deep','Minimal Shed'],img:'https://picsum.photos/seed/rw4/480/640'},
];

// thumb seeds for gallery variety
const thumbSeeds = ['a','b','c','d'];
let cart = JSON.parse(localStorage.getItem('preshCart') || '[]');
let currentProduct = null;
let qty = 1;
let isWishlisted = false;

function saveCart(){ localStorage.setItem('preshCart', JSON.stringify(cart)); }
function getCartTotal(){ return cart.reduce((s,i) => s + i.price * i.qty, 0); }
function getCartCount(){ return cart.reduce((s,i) => s + i.qty, 0); }

function updateCartUI(){
  const count = getCartCount();
  document.getElementById('navCartBadge').textContent = count;
  document.getElementById('cartCountPanel').textContent = count;
  document.getElementById('cartSubtotal').textContent = '₦' + getCartTotal().toLocaleString();
  const list = document.getElementById('cartItemsList');
  const empty = document.getElementById('cartEmpty');
  if (!cart.length){ empty.style.display='block'; list.innerHTML=''; list.appendChild(empty); return; }
  empty.style.display='none';
  const items = cart.map(item => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}"/>
      <div>
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-sub">${item.length} · ${item.color}</div>
        <div class="cart-item-price">₦${(item.price * item.qty).toLocaleString()} ${item.qty > 1 ? `(×${item.qty})` : ''}</div>
      </div>
      <button class="cart-item-remove" onclick="removeFromCart(${item.id},'${item.length}','${item.color}')">✕</button>
    </div>
  `).join('');
  list.innerHTML = items;
}

function removeFromCart(id, length, color){
  cart = cart.filter(i => !(i.id===id && i.length===length && i.color===color));
  saveCart(); updateCartUI();
}

function openCart(){ document.getElementById('cartPanel').classList.add('open'); document.getElementById('cartOverlay').classList.add('open'); document.body.style.overflow='hidden'; }
function closeCart(){ document.getElementById('cartPanel').classList.remove('open'); document.getElementById('cartOverlay').classList.remove('open'); document.body.style.overflow=''; }

function loadProduct(){
  const params = new URLSearchParams(window.location.search);
  const id = parseInt(params.get('id')) || 1;
  const p = PRODUCTS.find(x => x.id === id) || PRODUCTS[0];
  currentProduct = p;

  // breadcrumb
  document.getElementById('bcProduct').textContent = p.name;
  document.getElementById('bcCollection').textContent = p.sub;
  document.getElementById('bcCollection').href = `collection.html?collection=${p.collection}`;
  document.title = `PRESH HAIRS — ${p.name}`;

  // gallery
  document.getElementById('mainImg').src = p.img;
  document.getElementById('mainImg').alt = p.name;
  if(p.badge){
    const b = document.getElementById('galleryBadge');
    b.textContent = p.badge; b.style.display='block';
  }
  const thumbsEl = document.getElementById('galleryThumbs');
  thumbsEl.innerHTML = thumbSeeds.map((s,i) => `
    <div class="thumb ${i===0?'active':''}" onclick="switchThumb(this, 'https://picsum.photos/seed/${p.img.split('/seed/')[1].split('/')[0]}${s}/480/640')">
      <img src="https://picsum.photos/seed/${p.img.split('/seed/')[1].split('/')[0]}${s}/120/160" loading="lazy"/>
    </div>`).join('');

  // details
  document.getElementById('pCollection').textContent = p.sub;
  document.getElementById('pName').textContent = p.name;
  document.getElementById('pStars').textContent = p.rating;
  document.getElementById('pPrice').textContent = '₦' + p.price.toLocaleString();
  if(p.oldPrice){
    document.getElementById('pOldPrice').textContent = '₦' + p.oldPrice.toLocaleString();
    document.getElementById('pOldPrice').style.display='inline';
    const saved = Math.round((1 - p.price/p.oldPrice)*100);
    document.getElementById('pSave').textContent = `Save ${saved}%`;
    document.getElementById('pSave').style.display='inline-block';
  }

  // accordion desc
  document.getElementById('accDesc').innerHTML = `<p>${p.desc}</p><ul style="margin-top:0.8rem;">${p.tags.map(t=>`<li>${t}</li>`).join('')}</ul>`;

  // related
  const related = PRODUCTS.filter(x => x.collection===p.collection && x.id!==p.id).slice(0,4);
  document.getElementById('relatedGrid').innerHTML = related.map(r => `
    <a class="related-card" href="product.html?id=${r.id}">
      <div class="related-img"><img src="${r.img}" alt="${r.name}" loading="lazy"/></div>
      <div class="related-info">
        <h4>${r.name}</h4>
        <p class="price">₦${r.price.toLocaleString()}</p>
      </div>
    </a>`).join('');

  updateCartUI();
}

function switchThumb(el, src){
  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('mainImg').src = src;
}

function selectSize(btn, val){
  document.querySelectorAll('.size-opt:not(.unavailable)').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('selectedLength').textContent = val.replace(/&quot;/g,'"');
}
function selectColor(el, name){
  document.querySelectorAll('.color-opt').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('selectedColor').textContent = name;
}
function changeQty(delta){
  qty = Math.max(1, Math.min(10, qty + delta));
  document.getElementById('qtyInput').value = qty;
}

function handleAddToCart(){
  if(!currentProduct) return;
  const length = document.getElementById('selectedLength').textContent;
  const color = document.getElementById('selectedColor').textContent;
  const existing = cart.find(i => i.id===currentProduct.id && i.length===length && i.color===color);
  if(existing) existing.qty += qty;
  else cart.push({id:currentProduct.id, name:currentProduct.name, sub:currentProduct.sub, price:currentProduct.price, img:currentProduct.img, length, color, qty});
  saveCart(); updateCartUI();
  const btn = document.getElementById('addCartBtn');
  const txt = document.getElementById('addCartText');
  btn.classList.add('added');
  txt.textContent = '✓ Added to Cart';
  setTimeout(()=>{ btn.classList.remove('added'); txt.textContent='Add to Cart'; }, 2200);
  setTimeout(()=> openCart(), 400);
}

function toggleWishlist(){
  isWishlisted = !isWishlisted;
  const btn = document.getElementById('wishBtn');
  btn.textContent = isWishlisted ? '♥  Saved to Wishlist' : '♡  Save to Wishlist';
  btn.style.color = isWishlisted ? 'var(--gold)' : '';
  btn.style.borderColor = isWishlisted ? 'var(--gold)' : '';
}

function toggleAcc(header){
  const item = header.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.acc-item').forEach(i => i.classList.remove('open'));
  if(!isOpen) item.classList.add('open');
}

loadProduct();
</script>
