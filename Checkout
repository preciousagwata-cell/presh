<script>
// ══════════════════════════════════════════
// CONFIG — Replace with your real Paystack public key
// ══════════════════════════════════════════
const PAYSTACK_PUBLIC_KEY = 'pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx';
// To go live: replace with pk_live_... from your Paystack dashboard

// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
let cart = JSON.parse(localStorage.getItem('preshCart') || '[]');
let promoApplied = false;
let deliveryCost = 0;
let selectedDeliveryLabel = 'Standard Delivery';
let selectedPayMethod = 'paystack';
let currentStep = 1;
const PROMO_CODES = ['PRESH10','LUXE10','VIP10'];

// Demo cart if empty
if (!cart.length) {
  cart = [
    {id:1,name:'Executive Sleek Bob',sub:'9 to 5 Professional',price:85000,img:'https://picsum.photos/seed/pw1/480/640',length:'14"',color:'Jet Black',qty:1},
    {id:16,name:'Cambodian Wavy Raw',sub:'Raw Hairs',price:175000,img:'https://picsum.photos/seed/rw2/480/640',length:'16"',color:'Jet Black',qty:1}
  ];
}

// ══════════════════════════════════════════
// TOTALS
// ══════════════════════════════════════════
function subtotal(){ return cart.reduce((s,i)=>s+i.price*i.qty, 0); }
function discountAmt(){ return promoApplied ? Math.round(subtotal()*0.1) : 0; }
function deliveryFee(){
  if(deliveryCost > 0) return deliveryCost;
  return subtotal() >= 50000 ? 0 : 2500;
}
function grandTotal(){ return subtotal() - discountAmt() + deliveryFee(); }

// ══════════════════════════════════════════
// RENDER SIDEBAR
// ══════════════════════════════════════════
function renderSidebar(){
  document.getElementById('sidebarItems').innerHTML = cart.map(i=>`
    <div class="sidebar-item">
      <img class="sidebar-item-img" src="${i.img}" alt="${i.name}"/>
      <div style="flex:1;">
        <div class="sidebar-item-name">${i.name}</div>
        <div class="sidebar-item-sub">${i.length} · ${i.color}</div>
        <div class="sidebar-item-qty">Qty: ${i.qty}</div>
      </div>
      <div class="sidebar-item-price">₦${(i.price*i.qty).toLocaleString()}</div>
    </div>`).join('');

  const fee = deliveryFee();
  document.getElementById('sSubtotal').textContent = '₦'+subtotal().toLocaleString();
  document.getElementById('sDelivery').textContent = fee === 0 ? 'Free' : '₦'+fee.toLocaleString();
  document.getElementById('sTotal').textContent = '₦'+grandTotal().toLocaleString();

  if(promoApplied){
    document.getElementById('sDiscountRow').style.display='flex';
    document.getElementById('sDiscount').textContent = '-₦'+discountAmt().toLocaleString();
  }

  // Update standard delivery price label
  const stdFee = subtotal() >= 50000 ? 'Free' : '₦2,500';
  const el = document.getElementById('deliveryStandardPrice');
  if(el) el.textContent = stdFee;

  // Update pay button text with amount
  document.getElementById('payBtnText').textContent = `Pay ₦${grandTotal().toLocaleString()} →`;

  // Set bank ref
  const ref = 'PH-'+Math.random().toString(36).substr(2,6).toUpperCase();
  const bankRefEl = document.getElementById('bankRef');
  if(bankRefEl && bankRefEl.textContent === '—') bankRefEl.textContent = ref;
}

// ══════════════════════════════════════════
// STEP NAVIGATION
// ══════════════════════════════════════════
function goToStep(n){
  if(n > currentStep){
    // Validate before advancing
    if(currentStep === 1 && !validateStep1()) return;
  }

  // Hide current, show next
  document.getElementById(`step-${currentStep}`).classList.remove('active');
  document.getElementById(`step-${n}`).classList.add('active');

  // Update progress bar
  for(let i=1;i<=5;i++){
    const ps = document.getElementById(`ps-${i}`);
    ps.classList.remove('active','done');
    if(i < n+1) ps.classList.add('done');
    if(i === n+1) ps.classList.add('active');
  }

  currentStep = n;

  // Step-specific actions
  if(n === 3) buildReview();
  if(n === 4) renderSidebar();

  window.scrollTo({top:0, behavior:'smooth'});
}

// ══════════════════════════════════════════
// VALIDATION
// ══════════════════════════════════════════
function validateStep1(){
  let ok = true;
  const checks = [
    {id:'fFirst', type:'name'},
    {id:'fLast', type:'name'},
    {id:'fEmail', type:'email'},
    {id:'fPhone', type:'phone'},
    {id:'fStreet', type:'text'},
    {id:'fCity', type:'text'},
    {id:'fState', type:'select'},
  ];
  checks.forEach(c=>{
    const el = document.getElementById(c.id);
    if(!validateField(el, c.type)){
      showFieldError(c.id, true);
      ok = false;
    }
  });
  if(!ok) showToast('Please fill in all required fields','error');
  return ok;
}

function validateField(el, type){
  const v = el.value.trim();
  if(!v) return false;
  if(type==='email') return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  if(type==='phone') return /^(\+234|0)[789][01]\d{8}$/.test(v.replace(/\s/g,''));
  if(type==='select') return v !== '';
  return v.length >= 2;
}

function liveValidate(el, type){
  const valid = validateField(el, type);
  el.classList.toggle('valid', valid);
  el.classList.toggle('has-error', !valid && el.value.trim().length > 0);
  const tick = document.getElementById('tick-'+el.id);
  if(tick) tick.classList.toggle('show', valid);
  if(valid) showFieldError(el.id, false);
}

function showFieldError(id, show){
  const el = document.getElementById(id);
  const err = document.getElementById('err-'+id);
  if(el) el.classList.toggle('has-error', show);
  if(err) err.classList.toggle('show', show);
}

// ══════════════════════════════════════════
// DELIVERY
// ══════════════════════════════════════════
function selectDelivery(cost, optId, label){
  deliveryCost = cost;
  selectedDeliveryLabel = label;
  document.querySelectorAll('.delivery-opt').forEach(o=>o.classList.remove('selected'));
  document.getElementById(optId).classList.add('selected');
  renderSidebar();
}

// ══════════════════════════════════════════
// PAYMENT METHOD
// ══════════════════════════════════════════
function selectPayMethod(method, elemId){
  selectedPayMethod = method;
  document.querySelectorAll('.pay-method').forEach(m=>m.classList.remove('selected'));
  document.getElementById(elemId).classList.add('selected');

  document.getElementById('bankTransferDetails').style.display = method==='transfer' ? 'block' : 'none';
  document.getElementById('podDetails').style.display = method==='pod' ? 'block' : 'none';
  document.getElementById('paystackNote').style.display = method==='paystack' ? 'flex' : 'none';

  const payBtn = document.getElementById('payBtnText');
  if(method==='paystack') payBtn.textContent = `Pay ₦${grandTotal().toLocaleString()} →`;
  else if(method==='pod') payBtn.textContent = 'Confirm Order (Pay on Delivery)';
  else if(method==='transfer') payBtn.textContent = 'Confirm & Get Transfer Details';
}

// ══════════════════════════════════════════
// REVIEW STEP
// ══════════════════════════════════════════
function buildReview(){
  document.getElementById('reviewItems').innerHTML = cart.map(i=>`
    <div class="review-item">
      <img class="review-item-img" src="${i.img}" alt="${i.name}"/>
      <div class="review-item-info">
        <div class="review-item-name">${i.name}</div>
        <div class="review-item-sub">${i.sub} · ${i.length} · ${i.color} · Qty ${i.qty}</div>
      </div>
      <div class="review-item-price">₦${(i.price*i.qty).toLocaleString()}</div>
    </div>`).join('');

  const first = document.getElementById('fFirst').value;
  const last = document.getElementById('fLast').value;
  const street = document.getElementById('fStreet').value;
  const city = document.getElementById('fCity').value;
  const state = document.getElementById('fState').value;

  document.getElementById('reviewAddress').innerHTML =
    `<strong>${first} ${last}</strong><br/>${street}, ${city}, ${state}`;
  document.getElementById('reviewDelivery').textContent = selectedDeliveryLabel;
}

// ══════════════════════════════════════════
// PROMO
// ══════════════════════════════════════════
function applyPromo(){
  const code = document.getElementById('promoCode').value.trim().toUpperCase();
  const msg = document.getElementById('promoMsg');
  if(PROMO_CODES.includes(code)){
    promoApplied = true;
    msg.style.display = 'block';
    renderSidebar();
    showToast('Promo code applied — 10% off!');
  } else {
    msg.style.display = 'none';
    showToast('Invalid promo code','error');
  }
}

// ══════════════════════════════════════════
// PAYMENT INITIATION
// ══════════════════════════════════════════
function initiatePayment(){
  const btn = document.getElementById('payBtn');
  const spinner = document.getElementById('paySpinner');
  const btnText = document.getElementById('payBtnText');

  if(selectedPayMethod === 'paystack'){
    launchPaystack(btn, spinner, btnText);
  } else if(selectedPayMethod === 'pod'){
    confirmPODOrder();
  } else if(selectedPayMethod === 'transfer'){
    confirmTransferOrder();
  }
}

// ── PAYSTACK PAYMENT ──
function launchPaystack(btn, spinner, btnText){
  const email = document.getElementById('fEmail').value.trim();
  const first = document.getElementById('fFirst').value.trim();
  const last = document.getElementById('fLast').value.trim();
  const phone = document.getElementById('fPhone').value.trim();
  const amountKobo = grandTotal() * 100; // Paystack uses kobo
  const ref = 'PH-' + Date.now() + '-' + Math.random().toString(36).substr(2,6).toUpperCase();

  // Show loading state
  btn.disabled = true;
  btnText.textContent = 'Processing…';
  spinner.style.display = 'block';

  // Check if Paystack SDK loaded
  if(typeof PaystackPop === 'undefined'){
    // SDK not loaded — demo mode
    btn.disabled = false;
    btnText.textContent = `Pay ₦${grandTotal().toLocaleString()} →`;
    spinner.style.display = 'none';
    simulatePaystack(ref, email, first, last, phone);
    return;
  }

  const handler = PaystackPop.setup({
    key: PAYSTACK_PUBLIC_KEY,
    email: email,
    amount: amountKobo,
    currency: 'NGN',
    ref: ref,
    metadata: {
      custom_fields: [
        {display_name:'Customer Name', variable_name:'customer_name', value:`${first} ${last}`},
        {display_name:'Phone', variable_name:'phone', value:phone},
        {display_name:'Delivery', variable_name:'delivery', value:selectedDeliveryLabel},
        {display_name:'Items', variable_name:'items', value:cart.map(i=>`${i.name} x${i.qty}`).join(', ')},
      ]
    },
    callback: function(response){
      // Payment successful
      btn.disabled = false;
      spinner.style.display = 'none';
      onPaymentSuccess(response.reference, 'Card / Bank (Paystack)', ref);
    },
    onClose: function(){
      // User closed the popup
      btn.disabled = false;
      btnText.textContent = `Pay ₦${grandTotal().toLocaleString()} →`;
      spinner.style.display = 'none';
      showToast('Payment cancelled. Your cart is safe.', 'error');
    }
  });

  handler.openIframe();
}

// Demo Paystack simulation (when SDK is not loaded / test mode)
function simulatePaystack(ref, email, first, last, phone){
  showToast('Opening Paystack… (Demo mode — no real charge)');

  // Simulate the popup delay
  setTimeout(()=>{
    const proceed = confirm(
      `PAYSTACK DEMO\n\n` +
      `Customer: ${first} ${last}\n` +
      `Email: ${email}\n` +
      `Amount: ₦${grandTotal().toLocaleString()}\n` +
      `Ref: ${ref}\n\n` +
      `Click OK to simulate successful payment\nClick Cancel to simulate failure`
    );
    if(proceed){
      onPaymentSuccess(ref, 'Card / Bank (Paystack)', ref);
    } else {
      onPaymentFailed();
    }
  }, 800);
}

// ── PAY ON DELIVERY ──
function confirmPODOrder(){
  const ref = 'PH-POD-' + Math.random().toString(36).substr(2,6).toUpperCase();
  onPaymentSuccess(ref, 'Pay on Delivery', ref);
}

// ── BANK TRANSFER ──
function confirmTransferOrder(){
  const ref = document.getElementById('bankRef').textContent;
  onPaymentSuccess(ref, 'Bank Transfer', ref);
}

// ══════════════════════════════════════════
// PAYMENT SUCCESS / FAILURE
// ══════════════════════════════════════════
function onPaymentSuccess(paystackRef, method, orderRef){
  // Clear cart
  localStorage.removeItem('preshCart');

  // Populate success screen
  const first = document.getElementById('fFirst').value;
  const last = document.getElementById('fLast').value;
  const street = document.getElementById('fStreet').value;
  const city = document.getElementById('fCity').value;
  const state = document.getElementById('fState').value;

  document.getElementById('successRef').textContent = `Order ${orderRef}`;
  document.getElementById('sPayMethod').textContent = method;
  document.getElementById('sAmount').textContent = '₦' + grandTotal().toLocaleString();
  document.getElementById('sAddress').textContent = `${street}, ${city}, ${state}`;

  // Save order to localStorage for account page
  const orders = JSON.parse(localStorage.getItem('preshOrders') || '[]');
  orders.unshift({
    id: orderRef,
    date: new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}),
    items: cart.map(i=>`${i.name} ×${i.qty}`).join(', '),
    total: grandTotal(),
    method,
    status: 'Processing',
    address: `${street}, ${city}, ${state}`,
    customer: `${first} ${last}`,
  });
  localStorage.setItem('preshOrders', JSON.stringify(orders));

  document.getElementById('successScreen').classList.add('show');
}

function onPaymentFailed(){
  document.getElementById('failedScreen').classList.add('show');
}

function retryPayment(){
  document.getElementById('failedScreen').classList.remove('show');
}

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
let toastTimer;
function showToast(msg, type=''){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type ? ' '+type : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3500);
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
renderSidebar();
</script>
