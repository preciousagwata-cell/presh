<script>
// ── DATA ──
const PRODUCTS = [
  {id:1,name:'Executive Sleek Bob',sub:'9 to 5 Professional',price:85000,img:'https://picsum.photos/seed/pw1/480/640'},
  {id:2,name:'Power Lace Front',sub:'9 to 5 Professional',price:120000,img:'https://picsum.photos/seed/pw2/480/640'},
  {id:3,name:'Boardroom Silk Press',sub:'9 to 5 Professional',price:95000,img:'https://picsum.photos/seed/pw3/480/640'},
  {id:5,name:'Velvet Straight 180%',sub:'9 to 5 Professional',price:140000,img:'https://picsum.photos/seed/pw5/480/640'},
  {id:7,name:'Campus Chic Curls',sub:'Students Collection',price:45000,img:'https://picsum.photos/seed/sw1/480/640'},
  {id:15,name:'Vietnamese Raw Bundle',sub:'Raw Hairs',price:150000,img:'https://picsum.photos/seed/rw1/480/640'},
];

const DEMO_ORDERS = [
  {id:'PH-A4X29K',date:'15 Mar 2025',items:'Executive Sleek Bob × 1',total:'₦85,000',status:'Delivered'},
  {id:'PH-B7R12L',date:'02 Feb 2025',items:'Presh Noir Absolue × 1',total:'₦65,000',status:'Delivered'},
  {id:'PH-C9M55T',date:'10 Jan 2025',items:'Velvet Straight 180% × 1',total:'₦140,000',status:'Delivered'},
];

// ── STATE ──
let currentUser = JSON.parse(localStorage.getItem('preshUser') || 'null');
let wishlist = JSON.parse(localStorage.getItem('preshWishlist') || '[1,3,5,7,15]');

function saveUser(u){ localStorage.setItem('preshUser', JSON.stringify(u)); currentUser = u; }
function saveWishlist(){ localStorage.setItem('preshWishlist', JSON.stringify(wishlist)); }

// ── INIT ──
window.addEventListener('DOMContentLoaded', () => {
  if(currentUser) showDashboard();
  else showAuth();
});

function showAuth(){
  document.getElementById('authScreen').classList.add('active');
  document.getElementById('dashboard').classList.remove('active');
}
function showDashboard(){
  document.getElementById('authScreen').classList.remove('active');
  document.getElementById('dashboard').classList.add('active');
  populateDashboard();
}

// ── AUTH TABS ──
function switchAuthTab(tab){
  document.getElementById('loginTab').classList.toggle('active', tab==='login');
  document.getElementById('registerTab').classList.toggle('active', tab==='register');
  document.getElementById('loginPanel').classList.toggle('active', tab==='login');
  document.getElementById('registerPanel').classList.toggle('active', tab==='register');
}

// ── TOGGLE PASSWORD ──
function togglePwd(id, btn){
  const input = document.getElementById(id);
  const show = input.type === 'password';
  input.type = show ? 'text' : 'password';
  btn.textContent = show ? 'Hide' : 'Show';
}

// ── PASSWORD STRENGTH ──
function checkStrength(val){
  const fill = document.getElementById('strengthFill') || document.getElementById('strengthFill2');
  const label = document.getElementById('strengthLabel');
  let score = 0;
  if(val.length >= 8) score++;
  if(/[A-Z]/.test(val)) score++;
  if(/[0-9]/.test(val)) score++;
  if(/[^a-zA-Z0-9]/.test(val)) score++;
  const w = [0,30,55,78,100][score];
  const colors = ['#ccc','#e74c3c','#e67e22','#f1c40f','#27ae60'];
  const labels = ['','Weak','Fair','Good','Strong'];
  if(fill){ fill.style.width=w+'%'; fill.style.background=colors[score]; }
  if(label) label.textContent = labels[score] || 'Strength';
  // also update security panel
  const fill2 = document.getElementById('strengthFill2');
  if(fill2){ fill2.style.width=w+'%'; fill2.style.background=colors[score]; }
}

// ── LOGIN ──
function handleLogin(){
  const email = document.getElementById('loginEmail').value.trim();
  const pwd = document.getElementById('loginPassword').value;
  let valid = true;
  if(!email || !email.includes('@')){ showErr('loginEmailErr',true); valid=false; } else showErr('loginEmailErr',false);
  if(!pwd){ showErr('loginPwdErr',true); valid=false; } else showErr('loginPwdErr',false);
  if(!valid) return;
  // Check stored users
  const users = JSON.parse(localStorage.getItem('preshUsers') || '[]');
  const user = users.find(u => u.email===email && u.password===pwd);
  if(!user && !(email==='demo@preshhairs.com' && pwd==='demo1234')){
    showErr('loginPwdErr',true);
    document.getElementById('loginPwdErr').textContent='Email or password is incorrect';
    return;
  }
  const loggedIn = user || {firstName:'Demo',lastName:'User',email,phone:'',joined:'January 2025'};
  saveUser(loggedIn);
  showToast(`Welcome back, ${loggedIn.firstName}! ✦`);
  setTimeout(()=>showDashboard(), 600);
}

// ── REGISTER ──
function handleRegister(){
  const first=document.getElementById('regFirst').value.trim();
  const last=document.getElementById('regLast').value.trim();
  const email=document.getElementById('regEmail').value.trim();
  const pwd=document.getElementById('regPassword').value;
  const confirm=document.getElementById('regConfirm').value;
  let valid=true;
  if(!first){showErr('regFirstErr',true);valid=false;}else showErr('regFirstErr',false);
  if(!last){showErr('regLastErr',true);valid=false;}else showErr('regLastErr',false);
  if(!email||!email.includes('@')){showErr('regEmailErr',true);valid=false;}else showErr('regEmailErr',false);
  if(pwd.length<8){showErr('regPwdErr',true);valid=false;}else showErr('regPwdErr',false);
  if(pwd!==confirm){showErr('regConfirmErr',true);valid=false;}else showErr('regConfirmErr',false);
  if(!document.getElementById('agreeTerms').checked){showToast('Please accept the Terms of Service');return;}
  if(!valid)return;
  const now=new Date();
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const joined=`${months[now.getMonth()]} ${now.getFullYear()}`;
  const newUser={firstName:first,lastName:last,email,phone:'',password:pwd,joined};
  const users=JSON.parse(localStorage.getItem('preshUsers')||'[]');
  users.push(newUser);
  localStorage.setItem('preshUsers',JSON.stringify(users));
  saveUser(newUser);
  showToast(`Welcome to PRESH HAIRS, ${first}! ✦`);
  setTimeout(()=>showDashboard(),600);
}

// ── SOCIAL LOGIN (DEMO) ──
function socialLogin(provider){
  const demoUser={firstName:'Presh',lastName:'Beauty',email:`user@${provider.toLowerCase()}.com`,phone:'',joined:'Today'};
  saveUser(demoUser);
  showToast(`Signed in with ${provider} ✦`);
  setTimeout(()=>showDashboard(),600);
}

// ── LOGOUT ──
function handleLogout(){
  localStorage.removeItem('preshUser');
  currentUser=null;
  showToast('Signed out successfully');
  setTimeout(()=>showAuth(),600);
}

// ── FORGOT PASSWORD ──
function openForgot(){ document.getElementById('forgotScreen').classList.add('open'); }
function closeForgot(){ document.getElementById('forgotScreen').classList.remove('open'); }
function sendReset(){
  const email=document.getElementById('forgotEmail').value;
  if(!email||!email.includes('@')){ showToast('Please enter a valid email'); return; }
  closeForgot();
  showToast('✓ Reset link sent — check your inbox');
}

// ── DASHBOARD ──
function populateDashboard(){
  if(!currentUser) return;
  const name = currentUser.firstName;
  document.getElementById('dashName').textContent = name;
  document.getElementById('dashMember').textContent = `PRESH Member since ${currentUser.joined||'2025'}`;
  document.getElementById('statWishlist').textContent = wishlist.length;
  // profile
  document.getElementById('avatarCircle').textContent = name[0].toUpperCase();
  document.getElementById('avatarName').textContent = `${currentUser.firstName} ${currentUser.lastName}`;
  document.getElementById('avatarEmail').textContent = currentUser.email;
  document.getElementById('pfFirst').value = currentUser.firstName;
  document.getElementById('pfLast').value = currentUser.lastName;
  document.getElementById('pfEmail').value = currentUser.email;
  document.getElementById('pfPhone').value = currentUser.phone||'';
  renderOrders();
  renderWishlist();
}

function renderOrders(){
  const body = document.getElementById('ordersTableBody');
  body.innerHTML = DEMO_ORDERS.map(o=>`
    <tr>
      <td style="font-weight:600;color:var(--coffee);">${o.id}</td>
      <td>${o.date}</td>
      <td>${o.items}</td>
      <td style="font-weight:600;">${o.total}</td>
      <td><span class="order-status status-${o.status.toLowerCase()}">${o.status}</span></td>
      <td><button class="order-view-btn" onclick="showToast('Order detail coming soon!')">View</button></td>
    </tr>`).join('');
}

function renderWishlist(){
  const grid = document.getElementById('wishlistGrid');
  const items = PRODUCTS.filter(p=>wishlist.includes(p.id));
  if(!items.length){
    grid.innerHTML=`<div class="wish-empty" style="grid-column:1/-1;"><h3>Nothing saved yet</h3><p>Browse our collections and save your favourites</p><a href="collection.html">Browse Collections</a></div>`;
    return;
  }
  grid.innerHTML = items.map(p=>`
    <div class="wish-card">
      <div class="wish-img"><img src="${p.img}" alt="${p.name}" loading="lazy"/></div>
      <div class="wish-info">
        <div class="wish-name">${p.name}</div>
        <div class="wish-price">₦${p.price.toLocaleString()}</div>
        <div class="wish-actions">
          <button class="wish-btn cart" onclick="moveToCart(${p.id})">Add to Cart</button>
          <button class="wish-btn remove" onclick="removeWishlist(${p.id})">Remove</button>
        </div>
      </div>
    </div>`).join('');
  document.getElementById('statWishlist').textContent = items.length;
}

function removeWishlist(id){
  wishlist = wishlist.filter(i=>i!==id);
  saveWishlist(); renderWishlist();
  showToast('Removed from wishlist');
}
function moveToCart(id){
  const p = PRODUCTS.find(x=>x.id===id);
  if(!p) return;
  let cart = JSON.parse(localStorage.getItem('preshCart')||'[]');
  const existing = cart.find(i=>i.id===id);
  if(existing) existing.qty++;
  else cart.push({id:p.id,name:p.name,sub:p.sub,price:p.price,img:p.img,length:'14"',color:'Jet Black',qty:1});
  localStorage.setItem('preshCart',JSON.stringify(cart));
  showToast(`${p.name} added to cart ✓`);
}

function saveProfile(){
  if(!currentUser)return;
  currentUser.firstName = document.getElementById('pfFirst').value;
  currentUser.lastName = document.getElementById('pfLast').value;
  currentUser.email = document.getElementById('pfEmail').value;
  currentUser.phone = document.getElementById('pfPhone').value;
  saveUser(currentUser);
  document.getElementById('avatarCircle').textContent = currentUser.firstName[0].toUpperCase();
  document.getElementById('avatarName').textContent = `${currentUser.firstName} ${currentUser.lastName}`;
  document.getElementById('avatarEmail').textContent = currentUser.email;
  document.getElementById('dashName').textContent = currentUser.firstName;
  document.getElementById('profileSaved').classList.add('show');
  setTimeout(()=>document.getElementById('profileSaved').classList.remove('show'),3000);
}

function changePassword(){
  const cur=document.getElementById('secCurrent').value;
  const nw=document.getElementById('secNew').value;
  const conf=document.getElementById('secConfirm').value;
  if(!cur){ showToast('Please enter your current password'); return; }
  if(nw.length<8){ showToast('New password must be at least 8 characters'); return; }
  if(nw!==conf){ showToast('Passwords do not match'); return; }
  if(currentUser){ currentUser.password=nw; saveUser(currentUser); }
  document.getElementById('secCurrent').value='';
  document.getElementById('secNew').value='';
  document.getElementById('secConfirm').value='';
  showToast('✓ Password updated successfully');
}

// ── PANEL SWITCHING ──
function switchPanel(name, btn){
  document.querySelectorAll('.dash-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.dash-nav-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  btn.classList.add('active');
}

// ── HELPERS ──
function showErr(id, show){ const el=document.getElementById(id); if(el) el.classList.toggle('show',show); }
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

// ── DEMO LOGIN TIP ──
window.addEventListener('DOMContentLoaded',()=>{
  if(!currentUser){
    setTimeout(()=>showToast('Demo: use demo@preshhairs.com / demo1234'),1200);
  }
});
</script>
