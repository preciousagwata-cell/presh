<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PRESH HAIRS — My Account</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root{
    --coffee:#3B1F0E;--coffee-mid:#6B3A20;--coffee-light:#A0623A;
    --ivory:#F5EFE6;--cream:#EDE4D5;--gold:#C9A84C;--gold-light:#E2C47A;
    --dark:#1A0E07;--text-dark:#2C1A0E;--text-mid:#5C3D25;--white:#FDFAF6;
    --green:#1e7c1e;--red:#c0392b;
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{font-family:'Montserrat',sans-serif;background:var(--ivory);color:var(--text-dark);min-height:100vh;}
  ::-webkit-scrollbar{width:6px;} ::-webkit-scrollbar-track{background:var(--cream);} ::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px;}

  /* ── NAV ── */
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.2rem 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(250,246,240,0.97);backdrop-filter:blur(12px);box-shadow:0 2px 30px rgba(59,31,14,0.08);}
  .nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;letter-spacing:0.18em;color:var(--coffee);text-decoration:none;}
  .nav-links{display:flex;gap:2rem;list-style:none;}
  .nav-links a{font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-mid);text-decoration:none;transition:color 0.3s;}
  .nav-links a:hover{color:var(--coffee);}
  .nav-right{display:flex;align-items:center;gap:1rem;}
  .nav-cart-btn{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.6rem 1.2rem;background:var(--coffee);color:var(--ivory);border:none;cursor:pointer;font-family:'Montserrat',sans-serif;text-decoration:none;transition:background 0.3s;}
  .nav-cart-btn:hover{background:var(--coffee-mid);}

  /* ── AUTH SCREEN (login / register) ── */
  .auth-screen{
    display:none; position:fixed; inset:0; z-index:500;
    background:var(--ivory); overflow-y:auto;
    padding-top:72px;
  }
  .auth-screen.active{display:flex;}
  .auth-inner{
    display:grid; grid-template-columns:1fr 1fr;
    min-height:calc(100vh - 72px); width:100%;
  }
  .auth-visual{
    position:relative; overflow:hidden;
    background:var(--dark);
  }
  .auth-visual-img{
    width:100%; height:100%; object-fit:cover;
    opacity:0.45; position:absolute; inset:0;
  }
  .auth-visual-content{
    position:relative; z-index:2;
    display:flex; flex-direction:column; justify-content:flex-end;
    padding:4rem;height:100%;
  }
  .auth-visual-content h2{
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(2rem,3.5vw,3rem); font-weight:300;
    color:var(--white); line-height:1.1; margin-bottom:1rem;
  }
  .auth-visual-content h2 em{font-style:italic;color:var(--gold-light);}
  .auth-visual-content p{font-size:0.72rem;color:rgba(245,239,230,0.5);letter-spacing:0.1em;line-height:1.8;}
  .auth-gold-line{width:50px;height:2px;background:var(--gold);margin-bottom:1.5rem;}

  .auth-form-side{
    background:var(--white); display:flex; flex-direction:column;
    justify-content:center; padding:4rem;
    overflow-y:auto;
  }
  .auth-tabs{display:flex;gap:0;margin-bottom:2.5rem;border-bottom:1px solid rgba(59,31,14,0.1);}
  .auth-tab{
    flex:1; padding:1rem 0; background:transparent; border:none;
    font-family:'Montserrat',sans-serif; font-size:0.65rem;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--text-mid);
    cursor:pointer; position:relative; transition:color 0.3s;
  }
  .auth-tab::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform 0.3s;}
  .auth-tab.active{color:var(--coffee);font-weight:600;}
  .auth-tab.active::after{transform:scaleX(1);}

  .auth-panel{display:none;}
  .auth-panel.active{display:block;}

  .auth-greeting{margin-bottom:2rem;}
  .auth-greeting h3{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--coffee);margin-bottom:0.3rem;}
  .auth-greeting p{font-size:0.7rem;color:var(--text-mid);letter-spacing:0.08em;}

  .form-group{margin-bottom:1.2rem;}
  .form-label{display:block;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-mid);margin-bottom:0.5rem;}
  .form-input{
    width:100%; padding:0.95rem 1rem;
    border:1px solid rgba(59,31,14,0.18); background:var(--ivory);
    font-family:'Montserrat',sans-serif; font-size:0.75rem;
    color:var(--text-dark); outline:none; transition:border-color 0.25s;
  }
  .form-input:focus{border-color:var(--gold);}
  .form-input.error{border-color:var(--red);}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .form-error{font-size:0.58rem;color:var(--red);margin-top:0.3rem;letter-spacing:0.05em;display:none;}
  .form-error.show{display:block;}

  .password-wrap{position:relative;}
  .password-toggle{position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--coffee-light);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;}

  .strength-bar{height:3px;background:rgba(59,31,14,0.1);margin-top:0.5rem;border-radius:2px;overflow:hidden;}
  .strength-fill{height:100%;width:0;transition:width 0.3s,background 0.3s;border-radius:2px;}

  .form-check{display:flex;align-items:flex-start;gap:0.7rem;margin-bottom:1.2rem;}
  .form-check input{margin-top:2px;accent-color:var(--gold);width:15px;height:15px;flex-shrink:0;}
  .form-check label{font-size:0.65rem;color:var(--text-mid);line-height:1.5;}
  .form-check a{color:var(--coffee-light);text-decoration:underline;}

  .btn-auth{
    width:100%; padding:1.1rem;
    background:var(--coffee); color:var(--ivory); border:none;
    font-family:'Montserrat',sans-serif; font-size:0.65rem;
    letter-spacing:0.3em; text-transform:uppercase; cursor:pointer;
    transition:all 0.3s; margin-bottom:1rem;
  }
  .btn-auth:hover{background:var(--coffee-mid);}
  .btn-auth:disabled{opacity:0.6;cursor:not-allowed;}

  .auth-divider{display:flex;align-items:center;gap:1rem;margin:1.2rem 0;font-size:0.58rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(92,61,37,0.4);}
  .auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:rgba(59,31,14,0.1);}

  .btn-social{
    width:100%; padding:0.9rem; display:flex; align-items:center;
    justify-content:center; gap:0.8rem;
    border:1px solid rgba(59,31,14,0.18); background:transparent;
    font-family:'Montserrat',sans-serif; font-size:0.62rem;
    letter-spacing:0.15em; text-transform:uppercase; color:var(--coffee);
    cursor:pointer; margin-bottom:0.6rem; transition:all 0.3s;
  }
  .btn-social:hover{background:var(--cream);}

  .forgot-link{font-size:0.6rem;color:var(--coffee-light);text-decoration:underline;cursor:pointer;text-align:right;display:block;margin-top:-0.5rem;margin-bottom:1.2rem;transition:color 0.2s;}
  .forgot-link:hover{color:var(--coffee);}

  /* ── DASHBOARD ── */
  .dashboard{display:none;padding-top:72px;min-height:100vh;}
  .dashboard.active{display:block;}

  .dash-hero{
    background:var(--coffee); padding:3rem 5%;
    display:flex; align-items:center; justify-content:space-between;
    flex-wrap:wrap; gap:1.5rem;
  }
  .dash-welcome{color:var(--ivory);}
  .dash-welcome p{font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem;}
  .dash-welcome h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,3vw,2.5rem);font-weight:300;}
  .dash-welcome h1 em{font-style:italic;color:var(--gold-light);}
  .dash-member{font-size:0.6rem;color:rgba(245,239,230,0.45);letter-spacing:0.15em;text-transform:uppercase;margin-top:0.5rem;}
  .dash-logout{padding:0.65rem 1.4rem;border:1px solid rgba(201,168,76,0.4);background:transparent;color:var(--gold-light);font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:all 0.3s;}
  .dash-logout:hover{background:rgba(201,168,76,0.15);}

  /* DASH STATS */
  .dash-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid rgba(59,31,14,0.08);}
  .stat-card{padding:2rem 2.5rem;background:var(--white);border-right:1px solid rgba(59,31,14,0.08);text-align:center;}
  .stat-card:last-child{border-right:none;}
  .stat-num{font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:var(--coffee);font-weight:400;}
  .stat-label{font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-mid);margin-top:0.3rem;}

  /* DASH LAYOUT */
  .dash-layout{display:grid;grid-template-columns:240px 1fr;gap:0;min-height:60vh;}

  /* SIDEBAR NAV */
  .dash-sidebar{background:var(--white);border-right:1px solid rgba(59,31,14,0.08);padding:2rem 0;}
  .dash-nav-item{
    display:flex; align-items:center; gap:0.8rem;
    padding:0.9rem 2rem; width:100%; background:transparent; border:none;
    font-family:'Montserrat',sans-serif; font-size:0.62rem;
    letter-spacing:0.15em; text-transform:uppercase; color:var(--text-mid);
    cursor:pointer; transition:all 0.25s; text-align:left;
    border-left:3px solid transparent;
  }
  .dash-nav-item:hover{background:var(--cream);color:var(--coffee);}
  .dash-nav-item.active{background:rgba(201,168,76,0.08);color:var(--coffee);font-weight:600;border-left-color:var(--gold);}
  .dash-nav-icon{font-size:1rem;width:20px;text-align:center;}
  .dash-nav-badge{margin-left:auto;background:var(--gold);color:var(--dark);font-size:0.5rem;padding:1px 5px;border-radius:2px;font-weight:700;}

  /* DASH CONTENT */
  .dash-content{background:var(--ivory);padding:2.5rem;}
  .dash-panel{display:none;}
  .dash-panel.active{display:block;}

  .panel-title{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--coffee);margin-bottom:0.3rem;}
  .panel-sub{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold);margin-bottom:2rem;}

  /* ORDERS TABLE */
  .orders-table{width:100%;border-collapse:collapse;background:var(--white);}
  .orders-table th{padding:1rem 1.2rem;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);background:var(--coffee);text-align:left;font-weight:600;}
  .orders-table td{padding:1.1rem 1.2rem;font-size:0.7rem;color:var(--text-mid);border-bottom:1px solid rgba(59,31,14,0.06);}
  .orders-table tr:last-child td{border-bottom:none;}
  .orders-table tr:hover td{background:rgba(245,239,230,0.5);}
  .order-status{font-size:0.55rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.3rem 0.8rem;border-radius:2px;font-weight:600;}
  .status-delivered{background:rgba(30,124,30,0.12);color:var(--green);}
  .status-processing{background:rgba(201,168,76,0.15);color:#8a6f1e;}
  .status-shipped{background:rgba(59,31,14,0.1);color:var(--coffee-mid);}
  .order-view-btn{font-size:0.58rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--coffee-light);background:none;border:none;cursor:pointer;text-decoration:underline;transition:color 0.2s;}
  .order-view-btn:hover{color:var(--coffee);}

  /* WISHLIST GRID */
  .wishlist-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
  .wish-card{background:var(--white);position:relative;overflow:hidden;cursor:pointer;transition:transform 0.3s,box-shadow 0.3s;}
  .wish-card:hover{transform:translateY(-5px);box-shadow:0 15px 40px rgba(59,31,14,0.12);}
  .wish-img{aspect-ratio:3/4;overflow:hidden;}
  .wish-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s;}
  .wish-card:hover .wish-img img{transform:scale(1.05);}
  .wish-info{padding:1rem;}
  .wish-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--coffee);margin-bottom:0.2rem;}
  .wish-price{font-size:0.78rem;font-weight:600;color:var(--coffee);}
  .wish-actions{display:flex;gap:0.5rem;margin-top:0.7rem;}
  .wish-btn{flex:1;padding:0.55rem;font-size:0.55rem;letter-spacing:0.15em;text-transform:uppercase;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;transition:all 0.25s;}
  .wish-btn.cart{background:var(--coffee);color:var(--ivory);}
  .wish-btn.cart:hover{background:var(--coffee-mid);}
  .wish-btn.remove{background:transparent;border:1px solid rgba(59,31,14,0.2);color:var(--text-mid);}
  .wish-btn.remove:hover{background:var(--cream);}
  .wish-empty{text-align:center;padding:4rem;color:var(--text-mid);}
  .wish-empty h3{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--coffee-light);margin-bottom:0.5rem;}
  .wish-empty p{font-size:0.68rem;margin-bottom:1.5rem;}
  .wish-empty a{display:inline-block;padding:0.8rem 2rem;background:var(--coffee);color:var(--ivory);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;transition:background 0.3s;}
  .wish-empty a:hover{background:var(--coffee-mid);}

  /* PROFILE FORM */
  .profile-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;}
  .profile-card{background:var(--white);padding:2rem;}
  .profile-card-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--coffee);margin-bottom:1.5rem;padding-bottom:0.8rem;border-bottom:1px solid rgba(59,31,14,0.08);}
  .avatar-section{display:flex;flex-direction:column;align-items:center;padding:2rem;background:var(--cream);margin-bottom:1.5rem;}
  .avatar-circle{width:80px;height:80px;border-radius:50%;background:var(--coffee);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--ivory);margin-bottom:1rem;border:3px solid var(--gold);}
  .avatar-name{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--coffee);}
  .avatar-email{font-size:0.62rem;color:var(--text-mid);}
  .btn-save{padding:0.9rem 2rem;background:var(--coffee);color:var(--ivory);border:none;font-family:'Montserrat',sans-serif;font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;cursor:pointer;transition:background 0.3s;margin-top:1rem;}
  .btn-save:hover{background:var(--coffee-mid);}
  .save-confirm{font-size:0.6rem;color:var(--green);letter-spacing:0.1em;margin-top:0.5rem;display:none;}
  .save-confirm.show{display:block;}

  /* ADDRESS CARDS */
  .address-cards{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;}
  .address-card{padding:1.5rem;background:var(--white);border:2px solid transparent;cursor:pointer;transition:border-color 0.25s;position:relative;}
  .address-card.default{border-color:var(--gold);}
  .address-badge{position:absolute;top:0.8rem;right:0.8rem;font-size:0.5rem;letter-spacing:0.15em;text-transform:uppercase;background:var(--gold);color:var(--dark);padding:0.25rem 0.6rem;}
  .address-card h5{font-size:0.65rem;font-weight:600;color:var(--coffee);letter-spacing:0.1em;margin-bottom:0.4rem;}
  .address-card p{font-size:0.65rem;color:var(--text-mid);line-height:1.7;}
  .address-edit{font-size:0.55rem;color:var(--coffee-light);text-decoration:underline;cursor:pointer;margin-top:0.6rem;display:block;background:none;border:none;font-family:'Montserrat',sans-serif;}

  /* NOTIFICATION PREFS */
  .notif-list{display:flex;flex-direction:column;gap:0;}
  .notif-item{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 0;border-bottom:1px solid rgba(59,31,14,0.08);}
  .notif-item:last-child{border-bottom:none;}
  .notif-info h5{font-size:0.68rem;font-weight:600;color:var(--coffee);margin-bottom:0.2rem;}
  .notif-info p{font-size:0.6rem;color:var(--text-mid);}
  .toggle-switch{position:relative;width:44px;height:24px;cursor:pointer;}
  .toggle-switch input{display:none;}
  .toggle-track{width:44px;height:24px;background:rgba(59,31,14,0.15);border-radius:12px;transition:background 0.3s;position:relative;}
  .toggle-thumb{position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:var(--white);transition:left 0.3s;box-shadow:0 1px 4px rgba(0,0,0,0.2);}
  .toggle-switch input:checked + .toggle-track{background:var(--gold);}
  .toggle-switch input:checked + .toggle-track .toggle-thumb{left:23px;}

  /* TOAST */
  .toast{position:fixed;bottom:2rem;right:2rem;z-index:9999;background:var(--coffee);color:var(--ivory);padding:1rem 1.8rem;display:flex;align-items:center;gap:0.8rem;font-size:0.68rem;letter-spacing:0.1em;transform:translateY(80px);opacity:0;transition:all 0.4s cubic-bezier(0.34,1.4,0.64,1);max-width:320px;}
  .toast.show{transform:translateY(0);opacity:1;}

  /* PASSWORD STRENGTH */
  .strength-labels{display:flex;justify-content:space-between;font-size:0.52rem;color:var(--text-mid);margin-top:0.3rem;}

  /* FORGOT PASSWORD SCREEN */
  .forgot-screen{display:none;position:fixed;inset:0;z-index:600;background:rgba(26,14,7,0.7);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:2rem;}
  .forgot-screen.open{display:flex;}
  .forgot-modal{background:var(--white);padding:3rem;max-width:420px;width:100%;text-align:center;}
  .forgot-modal h3{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--coffee);margin-bottom:0.5rem;}
  .forgot-modal p{font-size:0.68rem;color:var(--text-mid);line-height:1.8;margin-bottom:1.5rem;}
  .forgot-close{position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-mid);}

  @media(max-width:900px){
    .auth-inner{grid-template-columns:1fr;}
    .auth-visual{display:none;}
    .auth-form-side{padding:3rem 2rem;}
    .dash-layout{grid-template-columns:1fr;}
    .dash-sidebar{display:flex;overflow-x:auto;padding:0;border-right:none;border-bottom:1px solid rgba(59,31,14,0.08);}
    .dash-nav-item{border-left:none;border-bottom:3px solid transparent;white-space:nowrap;}
    .dash-nav-item.active{border-bottom-color:var(--gold);border-left-color:transparent;}
    .dash-stats{grid-template-columns:repeat(2,1fr);}
    .profile-grid,.address-cards{grid-template-columns:1fr;}
    .wishlist-grid{grid-template-columns:repeat(2,1fr);}
  }
  @media(max-width:600px){
    .nav-links{display:none;}
    .form-row{grid-template-columns:1fr;}
    .dash-stats{grid-template-columns:repeat(2,1fr);}
    .wishlist-grid{grid-template-columns:1fr;}
    .dash-content{padding:1.5rem;}
  }
</style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- FORGOT PASSWORD MODAL -->
<div class="forgot-screen" id="forgotScreen">
  <div class="forgot-modal" style="position:relative;">
    <button class="forgot-close" onclick="closeForgot()">✕</button>
    <h3>Reset Password</h3>
    <p>Enter your email address and we'll send you a link to reset your password.</p>
    <div class="form-group" style="text-align:left;">
      <label class="form-label">Email Address</label>
      <input class="form-input" id="forgotEmail" type="email" placeholder="your@email.com"/>
    </div>
    <button class="btn-auth" onclick="sendReset()" style="margin-top:0.5rem;">Send Reset Link</button>
  </div>
</div>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="preshhairs.html">PRESH HAIRS</a>
  <ul class="nav-links">
    <li><a href="preshhairs.html#story">Our Story</a></li>
    <li><a href="collection.html">Collections</a></li>
    <li><a href="preshhairs.html#perfumes">Perfumes</a></li>
  </ul>
  <div class="nav-right">
    <a href="cart.html" class="nav-cart-btn">🛍 Cart</a>
  </div>
</nav>

<!-- ════════════════════════════════════════
     AUTH SCREEN  (Login / Register)
════════════════════════════════════════ -->
<div class="auth-screen active" id="authScreen">
  <div class="auth-inner">

    <!-- LEFT VISUAL -->
    <div class="auth-visual">
      <img class="auth-visual-img" src="https://picsum.photos/seed/authvis/800/1000" alt=""/>
      <div class="auth-visual-content">
        <div class="auth-gold-line"></div>
        <h2>Beauty is<br/><em>your identity.</em></h2>
        <p>Sign in to unlock your wishlist, track orders, and access exclusive member-only collections.</p>
      </div>
    </div>

    <!-- RIGHT FORM -->
