];

// ══════════════════════════════════════════
// FILTER STATE
// ══════════════════════════════════════════
let state = {
  query: '',
  collections: [],
  minPrice: 0,
  maxPrice: 200000,
  ratings: [],
  colors: [],
  badges: [],
  lengths: [],
  sortBy: 'featured',
  view: 'grid',
  quickChip: '',
};

let wishlisted = new Set(JSON.parse(localStorage.getItem('preshWishlistIds')||'[]'));
let recentlyViewed = JSON.parse(localStorage.getItem('preshRecentViewed')||'[]');
let cartItems = JSON.parse(localStorage.getItem('preshCart')||'[]');
let toastTimer;
let suggestionIndex = -1;

// ══════════════════════════════════════════
// FILTER SIDEBAR HTML
// ══════════════════════════════════════════
function buildFilterUI(containerId){
  document.getElementById(containerId).innerHTML = `
  <div class="filter-group" id="fg-collection">
    <div class="filter-group-header" onclick="toggleGroup('fg-collection')">
      <span class="filter-group-title">Collection</span>
      <span class="filter-group-icon">▾</span>
    </div>
    <div class="filter-group-body" style="max-height:300px;">
      ${[
        {val:'professional',label:'9 to 5 Professional',count:6},
        {val:'student',label:'Students Collection',count:4},
        {val:'errand',label:'Errand & Gym',count:4},
        {val:'raw',label:'Raw Hairs',count:4},
        {val:'perfume',label:'Perfumes',count:3},
      ].map(c=>`
      <label class="filter-check">
        <input type="checkbox" value="${c.val}" onchange="toggleCollectionFilter('${c.val}',this.checked)" ${state.collections.includes(c.val)?'checked':''}/>
        <div class="check-box"></div>
        <span class="filter-check-label">${c.label}</span>
        <span class="filter-check-count">${c.count}</span>
      </label>`).join('')}
      <button class="clear-group-btn" onclick="clearGroup('collections')">Clear</button>
    </div>
  </div>

  <div class="filter-group" id="fg-price">
    <div class="filter-group-header" onclick="toggleGroup('fg-price')">
      <span class="filter-group-title">Price Range</span>
      <span class="filter-group-icon">▾</span>
    </div>
    <div class="filter-group-body" style="max-height:180px;">
      <div class="price-range-wrap">
        <div class="dual-range" id="rangeTrack">
          <div class="dual-range-fill" id="rangeFill"></div>
          <input type="range" class="range-input" id="rangeMin" min="0" max="200000" step="1000" value="${state.minPrice}" oninput="onPriceRange()"/>
          <input type="range" class="range-input" id="rangeMax" min="0" max="200000" step="1000" value="${state.maxPrice}" oninput="onPriceRange()"/>
        </div>
        <div class="price-labels">
          <span id="priceMinLabel">₦${state.minPrice.toLocaleString()}</span>
          <span id="priceMaxLabel">₦${state.maxPrice.toLocaleString()}</span>
        </div>
        <div class="price-inputs">
          <input class="price-input-field" id="priceMinInput" value="${state.minPrice}" placeholder="Min" oninput="onPriceInput('min',this.value)"/>
          <div class="price-sep">—</div>
          <input class="price-input-field" id="priceMaxInput" value="${state.maxPrice}" placeholder="Max" oninput="onPriceInput('max',this.value)"/>
        </div>
      </div>
    </div>
  </div>

  <div class="filter-group" id="fg-rating">
    <div class="filter-group-header" onclick="toggleGroup('fg-rating')">
      <span class="filter-group-title">Rating</span>
      <span class="filter-group-icon">▾</span>
    </div>
    <div class="filter-group-body" style="max-height:200px;">
      <div class="star-filter">
        ${[5,4,3,2].map(r=>`
        <label class="star-row">
          <input type="checkbox" value="${r}" onchange="toggleRatingFilter(${r},this.checked)" ${state.ratings.includes(r)?'checked':''}/>
          <span class="stars-visual">${'★'.repeat(r)}${'☆'.repeat(5-r)}</span>
          <span class="star-row-label">${r} star${r>1?'s':''} & up</span>
        </label>`).join('')}
      </div>
      <button class="clear-group-btn" onclick="clearGroup('ratings')">Clear</button>
    </div>
  </div>

  <div class="filter-group" id="fg-badge">
