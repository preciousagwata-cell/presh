}

// ══════════════════════════════════════════
// FILTER ACTIONS
// ══════════════════════════════════════════
function toggleCollectionFilter(val,checked){
  if(checked){ if(!state.collections.includes(val)) state.collections.push(val); }
  else state.collections = state.collections.filter(c=>c!==val);
  applyAll();
}
function toggleRatingFilter(val,checked){
  if(checked){ if(!state.ratings.includes(val)) state.ratings.push(val); }
  else state.ratings = state.ratings.filter(r=>r!==val);
  applyAll();
}
function toggleBadgeFilter(val,checked){
  if(checked){ if(!state.badges.includes(val)) state.badges.push(val); }
  else state.badges = state.badges.filter(b=>b!==val);
  applyAll();
}
function toggleColorFilter(name,el){
  el.classList.toggle('active');
  if(state.colors.includes(name)) state.colors = state.colors.filter(c=>c!==name);
  else state.colors.push(name);
  applyAll();
}
function onPriceRange(){
  let min = parseInt(document.getElementById('rangeMin').value);
  let max = parseInt(document.getElementById('rangeMax').value);
  if(min > max){ const t=min; min=max; max=t; }
  state.minPrice = min; state.maxPrice = max;
  document.getElementById('priceMinLabel').textContent = '₦'+min.toLocaleString();
  document.getElementById('priceMaxLabel').textContent = '₦'+max.toLocaleString();
  document.getElementById('priceMinInput').value = min;
  document.getElementById('priceMaxInput').value = max;
  updateRangeFill();
  applyAll();
}
function onPriceInput(which, val){
  const n = parseInt(val) || 0;
  if(which==='min'){ state.minPrice = n; document.getElementById('rangeMin').value = n; }
  else { state.maxPrice = n; document.getElementById('rangeMax').value = n; }
  updateRangeFill();
  applyAll();
}
function updateRangeFill(){
  const fill = document.getElementById('rangeFill');
  if(!fill) return;
  const pct1 = (state.minPrice/200000)*100;
  const pct2 = (state.maxPrice/200000)*100;
  fill.style.left = pct1+'%';
  fill.style.width = (pct2-pct1)+'%';
}
function clearGroup(key){
  state[key] = Array.isArray(state[key]) ? [] : 0;
  if(key==='minPrice') state.minPrice = 0;
  if(key==='maxPrice') state.maxPrice = 200000;
  buildFilterUI('sidebarFilterBody');
  buildFilterUI('drawerFilterBody');
  applyAll();
}
function clearAllFilters(){
  state.collections=[]; state.minPrice=0; state.maxPrice=200000;
  state.ratings=[]; state.colors=[]; state.badges=[];
  state.query=''; state.quickChip='';
  document.getElementById('searchInput').value='';
  document.getElementById('searchClear').classList.remove('show');
  document.querySelectorAll('.qf-chip').forEach((c,i)=>c.classList.toggle('active',i===0));
  buildFilterUI('sidebarFilterBody');
  buildFilterUI('drawerFilterBody');
  applyAll();
}
function clearSearch(){
  state.query='';
  document.getElementById('searchInput').value='';
  document.getElementById('searchClear').classList.remove('show');
  closeSuggestions();
  applyAll();
}
function quickFilter(val, el){
  document.querySelectorAll('.qf-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  state.quickChip = val;
  applyAll();
}
function toggleGroup(id){
  document.getElementById(id).classList.toggle('collapsed');
}

// ══════════════════════════════════════════
// SEARCH INPUT
// ══════════════════════════════════════════
let searchDebounce;
function onSearchInput(){
  const q = document.getElementById('searchInput').value;
  state.query = q;
  document.getElementById('searchClear').classList.toggle('show', q.length > 0);
  clearTimeout(searchDebounce);
  searchDebounce = setTimeout(()=>{ showSuggestions(q); applyAll(); }, 200);
}
function applySearch(){ closeSuggestions(); applyAll(); }
function onSearchKeydown(e){
  const sug = document.getElementById('suggestions');
  const items = sug.querySelectorAll('.suggestion-item');
  if(e.key==='ArrowDown'){ suggestionIndex=Math.min(suggestionIndex+1,items.length-1); highlightSuggestion(items); e.preventDefault(); }
  else if(e.key==='ArrowUp'){ suggestionIndex=Math.max(suggestionIndex-1,-1); highlightSuggestion(items); e.preventDefault(); }
  else if(e.key==='Enter'){ if(suggestionIndex>=0&&items[suggestionIndex]){ items[suggestionIndex].click(); } else applySearch(); }
  else if(e.key==='Escape') closeSuggestions();
}
function highlightSuggestion(items){
  items.forEach((el,i)=>el.style.background=i===suggestionIndex?'var(--cream)':'');
}

// ══════════════════════════════════════════
// SUGGESTIONS
// ══════════════════════════════════════════
function openSuggestions(){
  if(document.getElementById('searchInput').value.trim()) showSuggestions(document.getElementById('searchInput').value);
  else showTrendingSuggestions();
}
function closeSuggestions(){ document.getElementById('suggestions').classList.remove('open'); suggestionIndex=-1; }
function showTrendingSuggestions(){
  const trending = ['Executive Sleek Bob','Vietnamese Raw Bundle','Presh Noir Absolue','Power Lace Front','Campus Chic Curls'];
  document.getElementById('suggestions').innerHTML = `
    <div class="suggestion-section">
      <div class="suggestion-label">🔥 Trending</div>
      ${trending.map(t=>`<div class="suggestion-tag" onclick="selectSuggestion('${t}')"><span class="suggestion-tag-icon">↗</span>${t}</div>`).join('')}
    </div>
    <div class="suggestion-section">
      <div class="suggestion-label">Browse by Collection</div>
      ${['9 to 5 Professional','Students Collection','Errand & Gym','Raw Hairs','Perfumes'].map(c=>`<div class="suggestion-tag" onclick="selectSuggestion('${c}')"><span class="suggestion-tag-icon">⊞</span>${c}</div>`).join('')}
    </div>`;
  document.getElementById('suggestions').classList.add('open');
}
function showSuggestions(q){
  if(!q.trim()){ showTrendingSuggestions(); return; }
  const matches = ALL_PRODUCTS.filter(p=>
    p.name.toLowerCase().includes(q.toLowerCase()) ||
    p.sub.toLowerCase().includes(q.toLowerCase()) ||
    p.tags.some(t=>t.toLowerCase().includes(q.toLowerCase())) ||
    p.desc.toLowerCase().includes(q.toLowerCase())
  ).slice(0,5);

  const tagMatches = [...new Set(ALL_PRODUCTS.flatMap(p=>p.tags).filter(t=>t.toLowerCase().includes(q.toLowerCase())))].slice(0,4);

  let html = '';
  if(matches.length){
    html += `<div class="suggestion-section"><div class="suggestion-label">Products</div>`;
    html += matches.map(p=>`
      <div class="suggestion-item" onclick="goToProduct(${p.id})">
        <img class="suggestion-img" src="${p.img}" alt="${p.name}"/>
        <div class="suggestion-info">
          <div class="suggestion-name">${highlight(p.name,q)}</div>
          <div class="suggestion-sub">${p.sub}</div>
        </div>
        <div class="suggestion-price">₦${p.price.toLocaleString()}</div>
      </div>`).join('');
    html += `</div>`;
  }
  if(tagMatches.length){
    html += `<div class="suggestion-section"><div class="suggestion-label">Tags</div>`;
    html += tagMatches.map(t=>`<div class="suggestion-tag" onclick="selectSuggestion('${t}')"><span class="suggestion-tag-icon">🏷</span>${t}</div>`).join('');
    html += `</div>`;
  }
  if(!matches.length && !tagMatches.length){
    html = `<div class="suggestion-no-results">No results for "<strong>${q}</strong>" — try a different term</div>`;
  }
  document.getElementById('suggestions').innerHTML = html;
  document.getElementById('suggestions').classList.add('open');
}
function highlight(text, q){
  if(!q) return text;
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return text.replace(re,'<mark style="background:rgba(201,168,76,0.3);padding:0 1px;">$1</mark>');
}
function selectSuggestion(term){
  document.getElementById('searchInput').value = term;
  state.query = term;
  document.getElementById('searchClear').classList.add('show');
  closeSuggestions();
  applyAll();
}
function goToProduct(id){ window.location.href=`product.html?id=${id}`; }
document.addEventListener('click',e=>{ if(!e.target.closest('.search-bar-wrap')) closeSuggestions(); });

// ══════════════════════════════════════════
// SORT & VIEW
// ══════════════════════════════════════════
function sortProducts(val){ state.sortBy=val; applyAll(); }
function setView(v){
  state.view=v;
  const grid=document.getElementById('productsGrid');
  grid.classList.remove('list-view','two-col');
  if(v==='list') grid.classList.add('list-view');
  document.getElementById('gridBtn').classList.toggle('active',v==='grid');
  document.getElementById('listBtn').classList.toggle('active',v==='list');
}

// ══════════════════════════════════════════
// CORE FILTER & RENDER
// ══════════════════════════════════════════
function getFiltered(){
  let data = [...ALL_PRODUCTS];

  // Text search
  if(state.query.trim()){
    const q = state.query.toLowerCase();
    data = data.filter(p=>
      p.name.toLowerCase().includes(q)||
      p.sub.toLowerCase().includes(q)||
      p.desc.toLowerCase().includes(q)||
      p.tags.some(t=>t.toLowerCase().includes(q))
    );
  }

  // Quick chip
  if(state.quickChip){
    if(state.quickChip==='sale') data=data.filter(p=>p.badge==='Sale');
    else if(state.quickChip==='new') data=data.filter(p=>p.badge==='New');
    else if(state.quickChip==='premium') data=data.filter(p=>p.badge==='Premium');
    else if(state.quickChip==='under50') data=data.filter(p=>p.price<50000);
    else if(state.quickChip==='over100') data=data.filter(p=>p.price>=100000);
    else data=data.filter(p=>p.collection===state.quickChip);
  }

  // Collections
  if(state.collections.length) data=data.filter(p=>state.collections.includes(p.collection));

  // Price
  data=data.filter(p=>p.price>=state.minPrice && p.price<=state.maxPrice);

  // Rating
  if(state.ratings.length) data=data.filter(p=>state.ratings.some(r=>p.rating>=r));

  // Badges
  if(state.badges.length) data=data.filter(p=>state.badges.includes(p.badge));

  // Colors
  if(state.colors.length) data=data.filter(p=>state.colors.some(c=>p.colors.includes(c)));

  // Sort
  if(state.sortBy==='price-asc') data.sort((a,b)=>a.price-b.price);
  else if(state.sortBy==='price-desc') data.sort((a,b)=>b.price-a.price);
  else if(state.sortBy==='newest') data.sort((a,b)=>b.id-a.id);
  else if(state.sortBy==='rating') data.sort((a,b)=>b.rating-a.rating||b.reviews-a.reviews);
  else if(state.sortBy==='name-asc') data.sort((a,b)=>a.name.localeCompare(b.name));

  return data;
}

function applyAll(){
  const results = getFiltered();
  renderResults(results);
  updateActiveFiltersBar();
  updateFilterCountBadge();
}

function renderResults(data){
  document.getElementById('resultCount').textContent = data.length;
  document.getElementById('heroResultCount').textContent = `${data.length} product${data.length!==1?'s':''}`;

  const q = state.query;
  const termEl = document.getElementById('searchTermDisplay');
  termEl.innerHTML = q ? `for <em style="font-style:italic;color:var(--coffee);">"${q}"</em>` : '';

  if(!data.length){
    document.getElementById('productsGrid').innerHTML = `
      <div class="no-results">
        <h3>No products found</h3>
        <p>Try adjusting your search or filters — or explore these popular terms:</p>
        <div class="no-results-suggestions">
          ${['Lace Front','Straight','Curly','Raw','Oud','Silk Press'].map(t=>`<div class="nr-tag" onclick="selectSuggestion('${t}')">${t}</div>`).join('')}
        </div>
        <button class="btn-clear-search" onclick="clearAllFilters()">Clear All Filters</button>
      </div>`;
    return;
  }

  document.getElementById('productsGrid').innerHTML = data.map((p,i)=>`
    <div class="product-card" style="animation-delay:${Math.min(i,8)*0.05}s;" onclick="goToProduct(${p.id})" data-id="${p.id}">
      <div class="card-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        ${p.badge?`<span class="card-badge badge-${p.badge.toLowerCase()}">${p.badge}</span>`:''}
        <button class="card-wish ${wishlisted.has(p.id)?'wishlisted':''}" onclick="event.stopPropagation();toggleWishlist(${p.id},this)" title="Wishlist">
          ${wishlisted.has(p.id)?'♥':'♡'}
        </button>
        <div class="card-actions">
          <button class="card-action-btn add" onclick="event.stopPropagation();addToCart(${p.id})">Add to Cart</button>
          <button class="card-action-btn view" onclick="event.stopPropagation();goToProduct(${p.id})">View</button>
        </div>
      </div>
      <div class="card-body">
        <div class="card-collection">${p.sub}</div>
        <div class="card-name">${highlight(p.name, state.query)}</div>
        <div class="card-rating">
          <span class="card-stars">${'★'.repeat(p.rating)}${'☆'.repeat(5-p.rating)}</span>
          <span class="card-review-count">(${p.reviews})</span>
        </div>
        <div class="list-desc">${highlight(p.desc, state.query)}</div>
        <div class="list-tags">${p.tags.map(t=>`<span class="list-tag">${t}</span>`).join('')}</div>
        <div class="card-price-row">
          <span class="card-price">₦${p.price.toLocaleString()}</span>
          ${p.oldPrice?`<span class="card-old-price">₦${p.oldPrice.toLocaleString()}</span>`:''}
        </div>
        <div class="list-actions">
          <button class="list-btn primary" onclick="event.stopPropagation();addToCart(${p.id})">Add to Cart</button>
          <button class="list-btn secondary" onclick="event.stopPropagation();goToProduct(${p.id})">View Details</button>
        </div>
      </div>
      <div class="card-notify" id="notify-${p.id}">✓ Added to Cart</div>
    </div>`).join('');
}

// ══════════════════════════════════════════
// ACTIVE FILTERS BAR
// ══════════════════════════════════════════
function updateActiveFiltersBar(){
  const tags = [];
  if(state.query) tags.push({label:`"${state.query}"`, clear:()=>{state.query='';document.getElementById('searchInput').value='';document.getElementById('searchClear').classList.remove('show');}});
  state.collections.forEach(c=>{
    const labels={professional:'9-5 Professional',student:'Students',errand:'Errand & Gym',raw:'Raw Hairs',perfume:'Perfumes'};
    tags.push({label:labels[c], clear:()=>{ state.collections=state.collections.filter(x=>x!==c); buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }});
  });
  if(state.minPrice>0) tags.push({label:`From ₦${state.minPrice.toLocaleString()}`, clear:()=>{ state.minPrice=0; buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }});
  if(state.maxPrice<200000) tags.push({label:`To ₦${state.maxPrice.toLocaleString()}`, clear:()=>{ state.maxPrice=200000; buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }});
  state.ratings.forEach(r=> tags.push({label:`${r}★+`, clear:()=>{ state.ratings=state.ratings.filter(x=>x!==r); buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }}));
  state.badges.forEach(b=> tags.push({label:b, clear:()=>{ state.badges=state.badges.filter(x=>x!==b); buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }}));
  state.colors.forEach(c=> tags.push({label:c, clear:()=>{ state.colors=state.colors.filter(x=>x!==c); buildFilterUI('sidebarFilterBody'); buildFilterUI('drawerFilterBody'); }}));
  if(state.quickChip) tags.push({label:`Chip: ${state.quickChip}`, clear:()=>{ state.quickChip=''; document.querySelectorAll('.qf-chip').forEach((c,i)=>c.classList.toggle('active',i===0)); }});

  const bar = document.getElementById('activeFiltersBar');
  const tagsEl = document.getElementById('activeFilterTags');

  if(!tags.length){ bar.classList.add('hidden'); return; }
  bar.classList.remove('hidden');
  tagsEl.innerHTML = tags.map((t,i)=>`
    <div class="filter-tag">
      ${t.label}
      <button onclick="removeFilterTag(${i})">✕</button>
    </div>`).join('');
  window._filterTagClears = tags.map(t=>t.clear);
}
function removeFilterTag(i){
  window._filterTagClears[i]();
  applyAll();
}
function updateFilterCountBadge(){
  const count = state.collections.length + state.ratings.length + state.badges.length + state.colors.length +
    (state.minPrice>0?1:0) + (state.maxPrice<200000?1:0);
  const badge = document.getElementById('filterCountBadge');
  badge.style.display = count > 0 ? 'inline' : 'none';
  badge.textContent = count;
}

// ══════════════════════════════════════════
// CART & WISHLIST
// ══════════════════════════════════════════
function addToCart(id){
  const p = ALL_PRODUCTS.find(x=>x.id===id);
  if(!p) return;
  cartItems = JSON.parse(localStorage.getItem('preshCart')||'[]');
  const existing = cartItems.find(i=>i.id===id);
  if(existing) existing.qty++;
  else cartItems.push({id:p.id,name:p.name,sub:p.sub,price:p.price,img:p.img,length:p.lengths[0]||'14"',color:p.colors[0]||'Jet Black',qty:1});
  localStorage.setItem('preshCart',JSON.stringify(cartItems));
  const n = document.getElementById(`notify-${id}`);
  if(n){ n.classList.add('show'); setTimeout(()=>n.classList.remove('show'),2200); }
  showToast(`${p.name} added to cart`);
  trackRecentlyViewed(id);
}
function toggleWishlist(id, btn){
  if(wishlisted.has(id)){ wishlisted.delete(id); btn.textContent='♡'; btn.classList.remove('wishlisted'); showToast('Removed from wishlist'); }
  else { wishlisted.add(id); btn.textContent='♥'; btn.classList.add('wishlisted'); showToast('Saved to wishlist ♥'); }
  localStorage.setItem('preshWishlistIds', JSON.stringify([...wishlisted]));
}

// ══════════════════════════════════════════
// RECENTLY VIEWED
// ══════════════════════════════════════════
function trackRecentlyViewed(id){
  recentlyViewed = recentlyViewed.filter(i=>i!==id);
  recentlyViewed.unshift(id);
  recentlyViewed = recentlyViewed.slice(0,6);
  localStorage.setItem('preshRecentViewed',JSON.stringify(recentlyViewed));
  renderRecentlyViewed();
}
function renderRecentlyViewed(){
  const items = recentlyViewed.map(id=>ALL_PRODUCTS.find(p=>p.id===id)).filter(Boolean);
  const sec = document.getElementById('recentlyViewedSection');
  const grid = document.getElementById('rvGrid');
  if(!items.length){ sec.style.display='none'; return; }
  sec.style.display='block';
  grid.innerHTML = items.map(p=>`
    <a class="rv-card" href="product.html?id=${p.id}">
      <div class="rv-img"><img src="${p.img}" alt="${p.name}" loading="lazy"/></div>
      <div class="rv-name">${p.name}</div>
      <div class="rv-price">₦${p.price.toLocaleString()}</div>
    </a>`).join('');
}

