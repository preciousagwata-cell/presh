      <span class="filter-group-title">Product Type</span>
      <span class="filter-group-icon">▾</span>
    </div>
    <div class="filter-group-body" style="max-height:200px;">
      ${['New','Sale','Bestseller','Premium','Popular'].map(b=>`
      <label class="filter-check">
        <input type="checkbox" value="${b}" onchange="toggleBadgeFilter('${b}',this.checked)" ${state.badges.includes(b)?'checked':''}/>
        <div class="check-box"></div>
        <span class="filter-check-label">${b}</span>
      </label>`).join('')}
      <button class="clear-group-btn" onclick="clearGroup('badges')">Clear</button>
    </div>
  </div>

  <div class="filter-group" id="fg-color">
    <div class="filter-group-header" onclick="toggleGroup('fg-color')">
      <span class="filter-group-title">Colour</span>
      <span class="filter-group-icon">▾</span>
